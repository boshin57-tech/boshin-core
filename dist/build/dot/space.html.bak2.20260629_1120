function mineAll(){planets.forEach(p=>{p.mining=true;});miningCount=planets.length;document.getElementById('mineCnt').textContent=miningCount;feedMsg('[전체채굴] 전체 행성 채굴 시작!');}
spC.addEventListener('click',e=>{const rect=spC.getBoundingClientRect(),mx=e.clientX-rect.left,my=e.clientY-rect.top;let f=null;planets.forEach(p=>{if(Math.hypot(mx-p.x,my-p.y)<p.r+10)f=p;});showInfo(f);if(curTab==='list')renderList();});
