<script>
// ===== 3중 좌표 시스템 =====
const COLS='ABCDEFGHJKLMNOPQRST'.split('');
let starMapData=null;
let curL1=null,curL2=null,curL3=null;
let miningCoords={};

// star_map.json 로드
fetch('/dot/space/star_map.json').then(r=>r.json()).then(d=>{
  starMapData=d;
  console.log('[Space] 3중 좌표 로딩완료 — '+Object.keys(d.stars).length+'개 별');
  initCoordUI();
}).catch(e=>console.warn('[Space] star_map 로딩실패',e));

function initCoordUI(){
  // 기존 사이드바에 좌표 탭 추가
  const tabs=document.querySelector('.side-tabs');
  if(tabs&&!document.getElementById('coordTab')){
    const t=document.createElement('div');
    t.className='stab';t.id='coordTab';t.textContent='좌표';
    t.onclick=function(){swtab('coord',this);};
    tabs.appendChild(t);
  }
}

// 좌표 탭 렌더
function renderCoord(){
  const sb=document.getElementById('sideBody');
  if(!starMapData){sb.innerHTML='<div style="padding:10px;font-size:10px;color:rgba(255,255,255,0.3)">로딩중...</div>';return;}
  sb.innerHTML=`
  <div style="padding:4px 0 8px;border-bottom:1px solid rgba(255,255,255,0.06);margin-bottom:8px">
    <div style="font-size:9px;color:#FFD700;margin-bottom:6px">⭐ 3중 좌표 채굴 시스템</div>
    <div style="font-size:8px;color:rgba(255,255,255,0.4);line-height:1.6">
      L1 셀 → L2 광맥 → L3 정밀<br>
      <span style="color:#9b59b6">탐사</span> · <span style="color:#378add">개발</span> · <span style="color:#F5A623">채굴</span>
    </div>
  </div>
  <div style="font-size:9px;color:rgba(255,255,255,0.4);margin-bottom:6px">행성 선택 → 좌표 배정</div>
  <div id="coordPlanetList" style="display:flex;flex-direction:column;gap:3px;max-height:200px;overflow-y:auto">
  ${Object.entries(starMapData.stars).map(([name,d])=>`
    <div onclick="selectCoordPlanet('${name}')" style="padding:5px 8px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:5px;cursor:pointer;font-size:9px;color:rgba(255,255,255,0.6)">
      <span style="color:${d.color}">${name}</span>
      <span style="float:right;color:#F5A623">${d.sau} SAU</span><br>
      <span style="color:rgba(255,255,255,0.3)">${d.cells[0].addr}·${d.cells[1].addr}·${d.cells[2].addr}</span>
    </div>`).join('')}
  </div>
  <div id="coordDetail" style="margin-top:8px"></div>`;
}

function selectCoordPlanet(name){
  if(!starMapData)return;
  const d=starMapData.stars[name];
  curL1=d.cells[0].addr;
  curL2=null;curL3=null;
  const det=document.getElementById('coordDetail');
  if(!det)return;
  det.innerHTML=`
  <div style="border-top:1px solid rgba(255,255,255,0.06);padding-top:8px;margin-top:4px">
    <div style="font-size:11px;font-weight:500;color:${d.color};margin-bottom:6px">${name}</div>
    <div style="font-size:9px;color:rgba(255,255,255,0.4);margin-bottom:6px">${d.type_kr} · ${d.star}</div>
    ${d.cells.map((c,i)=>{
      const roleColor=['#9b59b6','#378add','#F5A623'][i];
      return `<div onclick="selectL1Cell('${c.addr}','${name}')" style="display:flex;justify-content:space-between;padding:5px 8px;margin-bottom:3px;background:rgba(255,255,255,0.03);border:1px solid ${roleColor}44;border-radius:5px;cursor:pointer;font-size:10px">
        <span style="color:${roleColor}">${c.role_kr}</span>
        <span style="color:#FFD700;font-family:monospace;font-weight:500">${c.addr}</span>
      </div>`;
    }).join('')}
    <div id="l2Panel"></div>
    <div id="l3Panel"></div>
    <div id="minePanel"></div>
  </div>`;
}

function selectL1Cell(addr,planet){
  curL1=addr;curL2=null;curL3=null;
  const p2=document.getElementById('l2Panel');
  if(!p2)return;
  // L2 그리드 324칸
  p2.innerHTML=`
  <div style="margin-top:8px;font-size:9px;color:#F5A623;margin-bottom:4px">L2 광맥 선택 — ${addr} 내부</div>
  <div style="display:grid;grid-template-columns:repeat(9,1fr);gap:1px;background:#000">
  ${COLS.slice(0,18).map(c=>Array.from({length:18},(_,r)=>{
    const id=c+(r+1);
    const isMining=miningCoords[addr+'_'+id];
    return `<div onclick="selectL2('${addr}','${id}','${planet}')" title="${id}" style="width:100%;aspect-ratio:1;background:${isMining?'#F5A62344':'rgba(255,255,255,0.04)'};border:0.5px solid ${isMining?'#F5A623':'rgba(255,255,255,0.08)'};cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:5px;color:${isMining?'#F5A623':'transparent'}" onmouseover="this.style.background='#F5A62333'" onmouseout="this.style.background='${isMining?"#F5A62344":"rgba(255,255,255,0.04)"}'">⛏</div>`;
  }).join('')).join('')}
  </div>`;
  document.getElementById('l3Panel').innerHTML='';
  document.getElementById('minePanel').innerHTML='';
}

function selectL2(l1,l2addr,planet){
  curL2=l2addr;curL3=null;
  const p3=document.getElementById('l3Panel');
  if(!p3)return;
  p3.innerHTML=`
  <div style="margin-top:6px;font-size:9px;color:#27AE60;margin-bottom:4px">L3 정밀좌표 — ${l2addr} 내부</div>
  <div style="display:grid;grid-template-columns:repeat(9,1fr);gap:1px;background:#000">
  ${COLS.slice(0,18).map(c=>Array.from({length:18},(_,r)=>{
    const id=c+(r+1);
    const key=l1+'_'+l2addr+'_'+id;
    const isMining=miningCoords[key];
    return `<div onclick="selectL3('${l1}','${l2addr}','${id}','${planet}')" title="${id}" style="width:100%;aspect-ratio:1;background:${isMining?'#27AE6044':'rgba(255,255,255,0.04)'};border:0.5px solid ${isMining?'#27AE60':'rgba(255,255,255,0.08)'};cursor:pointer;font-size:5px;color:${isMining?'#27AE60':'transparent'};display:flex;align-items:center;justify-content:center" onmouseover="this.style.background='#27AE6033'" onmouseout="this.style.background='${isMining?"#27AE6044":"rgba(255,255,255,0.04)"}'">💎</div>`;
  }).join('')).join('')}
  </div>`;
  document.getElementById('minePanel').innerHTML='';
}

function selectL3(l1,l2,l3,planet){
  curL3=l3;
  const key=l1+'_'+l2+'_'+l3;
  const d=starMapData?starMapData.stars[planet]:null;
  const sau=d?d.sau:10;
  const mp=document.getElementById('minePanel');
  if(!mp)return;
  mp.innerHTML=`
  <div style="margin-top:8px;padding:8px;background:rgba(255,215,0,0.06);border:1px solid rgba(255,215,0,0.3);border-radius:6px">
    <div style="font-size:10px;font-weight:500;color:#FFD700;margin-bottom:4px">채굴 좌표 확정</div>
    <div style="font-family:monospace;font-size:11px;color:#FFD700;margin-bottom:6px">${l1} › ${l2} › ${l3}</div>
    <div style="font-size:9px;color:rgba(255,255,255,0.5);margin-bottom:6px">
      행성: ${planet}<br>
      SAU 수익: ${sau} SAU/사이클<br>
      분배: L1(10%) L2(20%) L3(70%)<br>
      상태: ${miningCoords[key]?'채굴중 ⛏':'대기중'}
    </div>
    <div onclick="startCoordMine('${l1}','${l2}','${l3}','${planet}',${sau})" style="padding:5px;background:${miningCoords[key]?'rgba(231,76,60,0.2)':'rgba(39,174,96,0.2)'};border:1px solid ${miningCoords[key]?'#e74c3c':'#27AE60'};border-radius:5px;text-align:center;cursor:pointer;font-size:10px;color:${miningCoords[key]?'#e74c3c':'#27AE60'}">
      ${miningCoords[key]?'⏹ 채굴 중지':'⛏ 이 좌표에서 채굴 시작'}
    </div>
  </div>`;
}

function startCoordMine(l1,l2,l3,planet,sau){
  const key=l1+'_'+l2+'_'+l3;
  if(miningCoords[key]){
    delete miningCoords[key];
    miningCount=Object.keys(miningCoords).length;
    feedMsg('[좌표채굴 중지] '+l1+'>'+l2+'>'+l3);
  } else {
    miningCoords[key]={l1,l2,l3,planet,sau,progress:0,totalSAU:0};
    miningCount=Object.keys(miningCoords).length;
    feedMsg('[좌표채굴 시작] '+l1+' › '+l2+' › '+l3+' — '+planet);
  }
  document.getElementById('mineCnt').textContent=miningCount;
  selectL3(l1,l2,l3,planet);
}

// 기존 swtab 확장
const _origSwtab=typeof swtab!=='undefined'?swtab:null;
function swtab(t,el){
  document.querySelectorAll('.stab').forEach(e=>e.classList.remove('on'));
  el.classList.add('on');
  if(t==='coord')renderCoord();
  else if(t==='info')renderInfo();
  else if(t==='list')renderList();
  else if(t==='mine')renderMine();
  else if(typeof _origSwtab==='function')_origSwtab(t,el);
}

// 좌표 채굴 사이클 통합
const _origLoop=requestAnimationFrame;
let coordFrame=0;
function coordMineLoop(){
  coordFrame++;
  if(coordFrame%120===0){
    Object.entries(miningCoords).forEach(([key,m])=>{
      m.progress+=0.05*m.sau;
      if(m.progress>=100){
        m.progress=0;
        const earned=m.sau*0.08;
        m.totalSAU+=earned;
        auBalance+=earned*0.01; // SAU→AU 자동변환 1%
        document.getElementById('auBal').textContent=auBalance.toFixed(2);
        feedMsg('[좌표채굴] '+m.l1+'>'+m.l2+'>'+m.l3+' +'+earned.toFixed(1)+' SAU');
      }
    });
  }
  requestAnimationFrame(coordMineLoop);
}
requestAnimationFrame(coordMineLoop);

// HUD에 SAU 표시 추가
setTimeout(()=>{
  const hud=document.querySelector('.hud-stats');
  if(hud&&!document.getElementById('sauStat')){
    const div=document.createElement('div');
    div.className='hs';div.id='sauStat';
    div.innerHTML='SAU <b id="sauBal">0.00</b>';
    hud.appendChild(div);
  }
  setInterval(()=>{
    const total=Object.values(miningCoords).reduce((s,m)=>s+m.totalSAU,0);
    const el=document.getElementById('sauBal');
    if(el)el.textContent=total.toFixed(1);
  },2000);
},1000);
</script>


<script>
// ===== 듀얼 채굴 시스템 =====
// 방법1: 행성 클릭 → 즉시 채굴 (심플)
// 방법2: 좌표탭 → 3단계 정밀 채굴

// 행성 캔버스 클릭 시 즉시 채굴 팝업
const _origClick=spC.onclick;
spC.addEventListener('click',function(e){
  const rect=spC.getBoundingClientRect();
  const mx=e.clientX-rect.left,my=e.clientY-rect.top;
  let found=null;
  planets.forEach(p=>{if(Math.hypot(mx-p.x,my-p.y)<p.r+10)found=p;});
  if(found){
    showInfo(found);
    if(curTab==='info')renderInfo();
    // 심플 채굴 플로팅 버튼 표시
    showQuickMine(found,e.clientX,e.clientY);
  } else {
    hideQuickMine();
  }
},{capture:false});

// 빠른 채굴 팝업
function showQuickMine(p,x,y){
  let popup=document.getElementById('quickMinePopup');
  if(!popup){
    popup=document.createElement('div');
    popup.id='quickMinePopup';
    popup.style.cssText='position:fixed;z-index:100;background:rgba(0,4,8,0.97);border:1px solid rgba(255,215,0,0.4);border-radius:10px;padding:10px 14px;font-family:monospace;min-width:180px;pointer-events:all';
    document.getElementById('uni').appendChild(popup);
  }
  // 위치 조정
  const ux=document.getElementById('uni').getBoundingClientRect();
  popup.style.left=Math.min(x-ux.left+10,ux.width-200)+'px';
  popup.style.top=Math.max(y-ux.top-120,10)+'px';
  popup.style.display='block';

  const isMining=p.mining;
  const coord=getAutoCoord(p.name);
  popup.innerHTML=`
    <div style="font-size:11px;font-weight:500;color:${p.pt.color};margin-bottom:6px">${p.name}</div>
    <div style="font-size:9px;color:rgba(255,255,255,0.4);margin-bottom:8px">${p.pt.name} · ${p.dotAU} SAU/사이클</div>
    <div style="font-size:9px;color:rgba(255,215,0,0.5);margin-bottom:8px;font-family:monospace">${coord}</div>
    <div style="display:flex;flex-direction:column;gap:4px">
      <div onclick="quickStartMine('${p.name}')" style="padding:6px 10px;background:${isMining?'rgba(231,76,60,0.2)':'rgba(39,174,96,0.15)'};border:1px solid ${isMining?'#e74c3c':'#27AE60'};border-radius:6px;cursor:pointer;font-size:10px;color:${isMining?'#e74c3c':'#27AE60'};text-align:center">
        ${isMining?'⏹ 채굴 중지':'⛏ 즉시 채굴 시작'}
      </div>
      <div onclick="openPreciseMine('${p.name}')" style="padding:6px 10px;background:rgba(255,215,0,0.08);border:1px solid rgba(255,215,0,0.3);border-radius:6px;cursor:pointer;font-size:10px;color:#FFD700;text-align:center">
        🎯 정밀 좌표 채굴
      </div>
      <div onclick="hideQuickMine()" style="padding:4px;text-align:center;font-size:9px;color:rgba(255,255,255,0.3);cursor:pointer">닫기</div>
    </div>`;
}

function hideQuickMine(){
  const p=document.getElementById('quickMinePopup');
  if(p)p.style.display='none';
}

// 자동 좌표 생성 (행성명 기반)
function getAutoCoord(name){
  if(!starMapData||!starMapData.stars[name])return '좌표 로딩중...';
  const d=starMapData.stars[name];
  const l1=d.cells[2].addr; // 채굴칸
  const l2='K'+((name.charCodeAt(0)%18)+1);
  const l3='C'+((name.charCodeAt(1)%18)+1);
  return l1+' › '+l2+' › '+l3;
}

// 즉시 채굴 시작
function quickStartMine(name){
  const p=planets.find(pl=>pl.name===name);
  if(!p)return;
  p.mining=!p.mining;
  miningCount=planets.filter(pl=>pl.mining).length;
  document.getElementById('mineCnt').textContent=miningCount;
  feedMsg(p.mining?'[심플채굴] '+name+' 채굴 시작! '+p.dotAU+' SAU/사이클':'[심플채굴] '+name+' 중지');
  hideQuickMine();
  if(curTab==='info')renderInfo();
  if(curTab==='mine')renderMine();
}

// 정밀 채굴로 전환
function openPreciseMine(name){
  hideQuickMine();
  // 좌표 탭으로 전환
  const coordTab=document.getElementById('coordTab');
  if(coordTab){
    swtab('coord',coordTab);
    setTimeout(()=>selectCoordPlanet(name),300);
  }
}

// 행성 위 SAU 채굴 표시 (캔버스 오버레이)
const _origDrawPlanets=drawPlanets;
function drawPlanets(){
  _origDrawPlanets();
  // 정밀 채굴 좌표 표시
  Object.entries(miningCoords).forEach(([key,m])=>{
    const p=planets.find(pl=>pl.name===m.planet);
    if(!p)return;
    // 진행률 링
    spX.beginPath();
    spX.arc(p.x,p.y,p.r+12,-Math.PI/2,-Math.PI/2+Math.PI*2*(m.progress/100));
    spX.strokeStyle='#FFD700';
    spX.lineWidth=2;spX.stroke();
    // SAU 표시
    spX.fillStyle='#FFD700';
    spX.font='bold 8px monospace';
    spX.textAlign='center';
    spX.fillText(m.l1+'>'+m.l2+'>'+m.l3,p.x,p.y-p.r-16);
    spX.fillText(m.totalSAU.toFixed(1)+' SAU',p.x,p.y-p.r-6);
  });
}

// 하단 바 버튼 업데이트
setTimeout(()=>{
  const botbar=document.querySelector('.botbar');
  if(botbar){
    // 전체채굴 버튼 텍스트 업데이트
    const btns=botbar.querySelectorAll('.abtn');
    btns.forEach(b=>{
      if(b.textContent.includes('전체채굴')){
        b.innerHTML='⛏ 전체채굴<br><span style="font-size:8px;opacity:0.6">심플모드</span>';
        b.style.lineHeight='1.2';
      }
    });
    // 정밀채굴 버튼 추가
    const precBtn=document.createElement('button');
    precBtn.className='abtn';
    precBtn.style.borderColor='rgba(255,215,0,0.4)';
    precBtn.style.color='#FFD700';
    precBtn.innerHTML='🎯 정밀채굴<br><span style="font-size:8px;opacity:0.6">좌표모드</span>';
    precBtn.style.lineHeight='1.2';
    precBtn.onclick=()=>{
      const coordTab=document.getElementById('coordTab');
      if(coordTab)swtab('coord',coordTab);
    };
    botbar.insertBefore(precBtn,document.getElementById('feed'));
  }
},1000);
</script>

