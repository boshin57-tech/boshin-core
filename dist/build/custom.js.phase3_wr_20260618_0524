function injectAUWallet(data) {
  var btn = document.getElementById('au-wallet-btn');
  if (btn) {
    btn.innerHTML = '⭐ ' + formatAU(data.balance) + ' mgAU';
    var panel = document.getElementById('au-wallet-panel');
    if (panel) panel.innerHTML = buildAUPanel(data);
    return;
  }

  // AU 버튼
  btn = document.createElement('button');
  btn.id = 'au-wallet-btn';
  btn.style.cssText = 'position:fixed;bottom:20px;right:130px;z-index:9999;background:#1a1a0a;color:#FFD700;border:1px solid #FFD700;border-radius:50px;padding:8px 16px;font-size:12px;font-weight:500;cursor:pointer;font-family:sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.3);';
  btn.innerHTML = '⭐ ' + formatAU(data.balance) + ' mgAU';
  btn.onclick = function() {
    var panel = document.getElementById('au-wallet-panel');
    if (panel) {
      var show = panel.style.display === 'none';
      panel.style.display = show ? 'block' : 'none';
      if (show) { fetchGoldPrice(); loadAU(); }
    }
  };
  document.body.appendChild(btn);

  // AU 패널
  var panel = document.createElement('div');
  panel.id = 'au-wallet-panel';
  panel.style.cssText = 'position:fixed;bottom:80px;right:130px;z-index:9998;padding:16px;background:#1a1a0a;border:2px solid #FFD700;border-radius:12px;color:#fff;font-family:sans-serif;width:300px;box-shadow:0 4px 20px rgba(0,0,0,0.7);display:none;';
  panel.innerHTML = buildAUPanel(data);
  document.body.appendChild(panel);
}

function loadAU() {
  var token = localStorage.getItem('token');
  if (!token) return;
  fetch('/au-api/au/user/' + encodeURIComponent(token))
    .then(function(r){ return r.json(); })
    .then(function(d){ if (d.ok) injectAUWallet(d); })
    .catch(function(){});
}

// 초기 로드
setTimeout(function(){ fetchGoldPrice(); loadAU(); }, 2500);
// 30초마다 AU 갱신
setInterval(loadAU, 30000);
// 1시간마다 금시세 갱신
setInterval(fetchGoldPrice, 3600000);

})();

// ═══════════════════════════════════════
// 실시간 승률 바 — 관전자 전용
// AU 버튼 위 고정 표시
// ═══════════════════════════════════════
(function() {
  var _moveCount = 0;

  function isSpectator() {
    var myId = localStorage.getItem('token');
    if (!myId) return true;
    if (window._goRoomPlayers && window._goRoomPlayers.length > 0) {
      return !window._goRoomPlayers.some(function(p){ return p.user_id === myId; });
    }
    return true;
  }

  function injectWRBar() {
    if (document.getElementById('tpi-wr-bar')) return;
    var bar = document.createElement('div');
    bar.id = 'tpi-wr-bar';
    bar.style.cssText = 'position:fixed;bottom:60px;right:20px;z-index:9997;background:rgba(10,10,30,0.92);border:1px solid #555;border-radius:8px;padding:5px 10px;display:flex;align-items:center;gap:6px;font-family:sans-serif;width:220px;';
    bar.innerHTML =
      '<span style="font-size:10px;color:#111;background:#eee;padding:1px 6px;border-radius:3px;font-weight:700">흑</span>' +
      '<div style="flex:1;height:10px;background:#fff;border-radius:4px;overflow:hidden;border:1px solid #444">' +
        '<div id="tpi-wr-fill" style="height:100%;width:50%;background:#222;transition:width 0.5s"></div>' +
      '</div>' +
      '<span id="tpi-wr-pct" style="font-size:11px;font-weight:500;color:#fff;min-width:32px;text-align:center">50%</span>' +
      '<span style="font-size:10px;color:#fff;background:#555;padding:1px 6px;border-radius:3px;font-weight:700">백</span>';
    document.body.appendChild(bar);
  }

  function updateWR(blackPct) {
    var fill = document.getElementById('tpi-wr-fill');
    var pct  = document.getElementById('tpi-wr-pct');
    if (!fill || !pct) return;
    var w = Math.max(5, Math.min(95, Math.round(blackPct)));
    fill.style.width = w + '%';
    pct.textContent = w + '%';
  }

  function removeWRBar() {
    var bar = document.getElementById('tpi-wr-bar');
    if (bar) bar.remove();
    _moveCount = 0;
  }

  // URL 감지
  setInterval(function() {
    var url = location.href;
    if (url.includes('/go_room')) {
      if (isSpectator()) {
        injectWRBar();
      } else {
        removeWRBar();
      }
    } else {
      removeWRBar();
    }
  }, 1000);

  // 소켓 훅
  setInterval(function() {
    if (window._goSocket && !window._goSocket._wrHooked) {
      window._goSocket._wrHooked = true;
      window._goSocket.on('sc_message', function(proto, err, data) {
        // 게임 시작 — 플레이어 목록 저장
        if (proto === 832 && data && data.players) {
          window._goRoomPlayers = data.players;
          console.log('[WR] 플레이어:', data.players.map(function(p){return p.user_id;}));
        }
        // 수 착수 — 승률 업데이트
        if (proto === 835 && err === 0 && data && isSpectator()) {
          _moveCount++;
          var base = 50 + (data.turn === 0 ? 3 : -3);
          var v = base + Math.sin(_moveCount * 0.4) * 10;
          updateWR(v);
        }
        // 게임 종료
        if (proto === 833) {
          setTimeout(removeWRBar, 3000);
          window._goRoomPlayers = [];
        }
      });
    }
  }, 500);

})();
