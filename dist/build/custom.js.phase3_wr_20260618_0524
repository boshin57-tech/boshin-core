(function(){
  // 832 캡처된 데이터에서 sjRule 초기화 (훅 전에 이미 받았을 경우)
  function initFromCaptured(){
    var d = window._captured832;
    if(!d) return;
    if(window._sjRuleInited) return;
    window._sjRuleInited = true;
    window._sjRule = (d.rule === 2 || (d.setting && d.setting.sunjang === 1));
    window._currentKomi = d.kpmi || d.komi || 6.5;
    window._sjHandicap = d.handicap || 0;
    console.log('[SCORING] captured832에서 초기화! _sjRule:', window._sjRule, 'rule:', d.rule, 'komi:', window._currentKomi);
  }
  function hookScoring(){
    initFromCaptured();
    var socks = [window._goSocket, window._reactGoSocket, window._custom2Socket, window._moveSocket];
    socks.forEach(function(sock){
      if(!sock || sock._scoringHooked2) return;
      sock._scoringHooked2 = true;
      sock.on('sc_message', function(protocol, err, data){
        if(protocol === 832){
          window._sjRule = (data && (data.rule === 2 || (data.setting && data.setting.sunjang === 1)));
          window._currentKomi = data.kpmi || data.komi || 6.5;
          window._sjHandicap = data && data.handicap || 0;
          window._sjRuleInited = true;
          console.log('[SCORING] GAME_START _sjRule:', window._sjRule, 'rule:', data.rule, 'komi:', window._currentKomi);
        }
        if(protocol === 1029){
          if(err !== 0) return;
          var D = data.bsum, B = data.wsum;
          var komi = window._currentKomi || 6.5;
          var handicap = window._sjHandicap || 0;
          var C = '';
          console.log('[SCORING] 1029 수신! _sjRule:', window._sjRule, 'bsum:', D, 'wsum:', B);
          if(window._sjRule){
            var sjDiff = D - B + (handicap === 0 ? komi : 0);
            var sjAbs = Math.abs(sjDiff).toFixed(1);
            var sjWin = sjDiff > 0 ? '흑 승 (Black wins)' : sjDiff < 0 ? '백 승 (White wins)' : '무승부 (Draw)';
            C = sjWin + '\n+' + sjAbs + '집\n\n[순장바둑 계가 상세]\n흑집: ' + D + '집 | 백집: ' + B + '집';
            C += handicap === 0 ? '\n덤: ' + komi + '집 (호선)' : '\n접바둑: 덤 없음';
            C += '\n\n* 순장바둑: 집만 계산\n(따내돌·코미 없음)';
          } else {
            var P = B - D + komi;
            C = P > 0 ? '백 승 (White wins) +' + Math.abs(P).toFixed(1) + '집' :
                P < 0 ? '흑 승 (Black wins) +' + Math.abs(P).toFixed(1) + '집' : '무승부 (Draw)';
            C += '\n\n[계가 상세]\n흑집: ' + D + ' | 백집: ' + B + '\n덤: ' + komi;
          }
          var old = document.getElementById('sj-score-modal');
          if(old) old.remove();
          var overlay = document.createElement('div');
          overlay.id = 'sj-score-modal';
          overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.75);z-index:9999999;display:flex;align-items:center;justify-content:center;';
          var box = document.createElement('div');
          box.style.cssText = 'background:#1a2a1a;border:2px solid #4caf50;border-radius:12px;padding:28px 36px;min-width:300px;max-width:420px;color:#fff;font-size:16px;white-space:pre-line;line-height:1.8;text-align:center;';
          box.innerText = C;
          var btn = document.createElement('button');
          btn.innerText = '확인';
          btn.style.cssText = 'margin-top:20px;width:100%;padding:12px;background:#4caf50;color:#fff;border:none;border-radius:8px;font-size:16px;cursor:pointer;font-weight:bold;';
          btn.onclick = function(){ overlay.remove(); };
          box.appendChild(btn);
          overlay.appendChild(box);
          document.body.appendChild(overlay);
          console.log('[SCORING] 모달 생성!');
        }
      });
    });
  }
  setInterval(hookScoring, 500);
})();

