  // history.push 가로채기 - go_room 이동을 올바른 방으로 교체
  function hookHistory(){
    var h=getHistory();
    if(!h||h._cdlgPushHooked)return;
    h._cdlgPushHooked=true;
    var origPush=h.push.bind(h);
    h.push=function(path){
      var content=getContent();
      if(content!==GT.GO && typeof path==='string' && path.indexOf('/go_room:')>=0){
        console.log('[CDlg] go_room 이동 차단! path:'+path+' content:'+content);
        // 올바른 방 생성 요청
        var sock=window._lobbySocket;
        var store=getStore();
        var user=store&&store.getState().authReducer.user;
