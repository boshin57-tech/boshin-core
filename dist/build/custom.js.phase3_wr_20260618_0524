// TPI 대시보드 — 개인정보 페이지 자동 삽입
// ═══════════════════════════════════════
(function() {
  var _tpiInjected = false;

  function getTierColor(tier) {
    return tier === 'platinum' ? '#378ADD'
         : tier === 'gold'     ? '#C9922A'
         : tier === 'silver'   ? '#888780'
         : '#8B5E3C'; // bronze
  }
  function getTierLabel(tier) {
    return tier === 'platinum' ? '💎 Platinum'
         : tier === 'gold'     ? '🥇 Gold'
         : tier === 'silver'   ? '🥈 Silver'
         : '🥉 Bronze';
  }

  function injectTPI(data) {
    if (document.getElementById('tpi-dashboard')) return;
    // 개인정보 페이지 내 go_level 표시 영역 찾기
    var target = document.querySelector('.MuiGrid-root') ||
                 document.querySelector('[class*="profile"]') ||
                 document.querySelector('[class*="mypage"]') ||
                 document.querySelector('[class*="info"]');
    if (!target) return;

    var color = getTierColor(data.tpi_tier);
    var tier  = getTierLabel(data.tpi_tier);

    // TPI 히스토리 미니 차트 데이터
    var hist  = data.tpi_history || [];
    var bars  = hist.slice(-10).map(function(h) { return h.value; });
    var maxV  = Math.max.apply(null, bars.concat([1000]));
    var barHTML = bars.map(function(v) {
      var h = Math.round((v / maxV) * 40);
      return '<div style="width:8px;height:'+h+'px;background:'+color+';border-radius:2px;opacity:0.8;margin:0 1px;align-self:flex-end"></div>';
    }).join('');

    // 최근 20국 승패
    var recent = data.recent_games || [];
    var recHTML = recent.slice(-10).map(function(r) {
      return '<span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:'+(r===1?'#1D9E75':'#E24B4A')+';margin:1px;font-size:9px;line-height:14px;text-align:center;color:#fff">'+(r===1?'W':'L')+'</span>';
    }).join('');

    var winRate = recent.length > 0
      ? Math.round(recent.filter(function(r){return r===1;}).length / recent.length * 100)
      : 0;

    // 토글 버튼 생성
    var btn = document.createElement('button');
    btn.id = 'tpi-toggle-btn';
    btn.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;background:#1a237e;color:#C9922A;border:1px solid #C9922A;border-radius:50px;padding:8px 16px;font-size:12px;font-weight:500;cursor:pointer;font-family:sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.3);';
    btn.innerHTML = '📊 TPI ' + data.tpi + ' (' + getTierLabel(data.tpi_tier).split(' ')[0] + ')';
    btn.onclick = function() {
      var panel = document.getElementById('tpi-dashboard');
      if (panel) {
        panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
      }
    };
    document.body.appendChild(btn);

    var div = document.createElement('div');
    div.id  = 'tpi-dashboard';
    div.style.display = 'none';
    div.style.cssText = 'position:fixed;bottom:80px;right:20px;z-index:9998;padding:16px;background:#1e1e3f;border:2px solid '+color+';border-radius:12px;color:#fff;font-family:sans-serif;width:320px;box-shadow:0 4px 20px rgba(0,0,0,0.5);transition:background 0.2s,box-shadow 0.2s;';
    div.onmouseenter = function() {
      this.style.background = '#3a3a6e';
      this.style.boxShadow = '0 6px 30px rgba(0,0,0,0.8)';
      this.querySelectorAll('div').forEach(function(el){ el.style.color='#fff'; });
    };
    div.onmouseleave = function() {
      this.style.background = '#2a2a4e';
      this.style.boxShadow = '0 4px 20px rgba(0,0,0,0.5)';
    };
    div.innerHTML = [
      '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">',
        '<div>',
          '<div style="font-size:11px;letter-spacing:0.1em;color:#ccc;margin-bottom:2px;text-shadow:0 0 8px rgba(255,255,255,0.3)">TPI · TOBMATE PROFICIENCY INDEX</div>',
          '<div style="font-size:32px;font-weight:500;color:'+color+';text-shadow:0 0 12px '+color+'">'+data.tpi+'</div>',
        '</div>',
        '<div style="text-align:right">',
          '<div style="font-size:14px;font-weight:500;color:'+color+'">'+tier+'</div>',
          '<div style="font-size:12px;color:#ddd;margin-top:2px">승률 '+winRate+'%</div>',
        '</div>',
      '</div>',
      // TPI 바
      '<div style="background:#333;border-radius:4px;height:6px;margin-bottom:12px">',
        '<div style="width:'+Math.round(data.tpi/10)+'%;background:'+color+';height:100%;border-radius:4px;transition:width 0.5s"></div>',
      '</div>',
      // 히스토리 차트
      bars.length > 0 ? [
        '<div style="font-size:11px;color:#aaa;margin-bottom:4px">TPI 변화</div>',
        '<div style="display:flex;align-items:flex-end;height:44px;margin-bottom:12px">'+barHTML+'</div>',
      ].join('') : '',
      // 최근 대국
      recent.length > 0 ? [
        '<div style="font-size:11px;color:#aaa;margin-bottom:4px">최근 대국</div>',
        '<div style="margin-bottom:8px">'+recHTML+'</div>',
      ].join('') : '',
      // 등급 기준
      '<div style="font-size:10px;color:#aaa;border-top:1px solid #555;padding-top:8px;display:flex;gap:8px">',
        '<span style="color:#8B5E3C">Bronze 0</span>',
        '<span style="color:#888">Silver 400</span>',
        '<span style="color:#C9922A">Gold 600</span>',
        '<span style="color:#378ADD">Platinum 800</span>',
      '</div>',
    ].join('');

    target.insertBefore(div, target.firstChild);
    _tpiInjected = true;
    console.log('[TPI] 대시보드 삽입 완료 TPI:', data.tpi, tier);
  }

  function updateTpiPanel(data) {
    var btn = document.getElementById('tpi-toggle-btn');
    if (btn) btn.innerHTML = '📊 TPI ' + data.tpi + ' (' + getTierLabel(data.tpi_tier).split(' ')[0] + ')';
  }

  function loadTPI() {
    var token = localStorage.getItem('token');
    if (!token) return;
    fetch('/tpi-api/tpi/user/' + encodeURIComponent(token))
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.ok) injectTPI(d);
      })
      .catch(function(){});
  }

  // URL 변경 감지 (React SPA)
  var _lastUrl = '';
  setInterval(function() {
    var url = location.href;
    if (url === _lastUrl) return;
    _lastUrl = url;
    _tpiInjected = false;
    // 개인정보 페이지일 때만 로드
    if (url.includes('/profile') || url.includes('/mypage') || url.includes('/info') || url.includes('/personal') || url.includes('/myinfo')) {
      setTimeout(loadTPI, 800);
    }
  }, 500);

  // 사이드바 메뉴 클릭 감지
  document.addEventListener('click', function(e) {
    var txt = e.target && (e.target.textContent || '');
    if (txt.includes('개인정보') || txt.includes('My') || txt.includes('profile')) {
      _tpiInjected = false;
      setTimeout(loadTPI, 1000);
    }
  });

})();

