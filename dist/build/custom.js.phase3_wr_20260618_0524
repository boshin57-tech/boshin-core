(function(){
  var GT={GO:0,PUZZLE:1,PIECE_DESIGN:2,FFA:3,SKPNI:4,OMOK:5};
  var roomMap={1:'puzzle_room',2:'pdesign_room',3:'ffa_room',4:'skpni_room',5:'omok_room'};
  
  function getStore(){
    if(window._reduxStore)return window._reduxStore;
    var root=document.getElementById('root');
    var fk=Object.keys(root).find(function(k){return k.startsWith('__react');});
    function fs(n,d){if(!n||d>50)return null;try{if(n.memoizedProps&&n.memoizedProps.store&&n.memoizedProps.store.getState)return n.memoizedProps.store;var f=null;if(n.child)f=fs(n.child,d+1);if(!f&&n.sibling)f=fs(n.sibling,d+1);return f;}catch(e){return null;}}
    window._reduxStore=fs(root[fk],0);return window._reduxStore;
  }

  var lastPath = window.location.pathname;
  setInterval(function(){
    var path = window.location.pathname;
    if(path === lastPath) return;
    lastPath = path;
    
    // go_room으로 이동했을 때
    if(path.indexOf('/go_room:') >= 0){
      var store = getStore();
      if(!store) return;
      var content = store.getState().commonReducer.content;
      if(content === GT.GO) return; // 바둑탭이면 정상
      
      // 다른 콘텐츠 탭인데 go_room으로 들어간 경우
      var roomType = roomMap[content];
      if(!roomType) return;
      var roomId = path.split('/go_room:')[1];
      console.log('[REDIRECT] go_room 감지! content:'+content+' roomType:'+roomType);
      
      // 올바른 방 URL로 즉시 교체
      window.history.replaceState(null,'','/'+roomType+':'+roomId);
      window.dispatchEvent(new PopStateEvent('popstate'));
    }
  }, 100);
})();

