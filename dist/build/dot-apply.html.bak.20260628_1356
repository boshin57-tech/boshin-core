body{background:#020818;color:#fff;font-family:sans-serif;min-height:100vh}
.top{background:#0a0a1a;padding:10px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(245,166,35,0.2)}
.logo{color:#F5A623;font-weight:700;font-size:15px}
.wrap{max-width:640px;margin:24px auto;padding:0 16px}
.hero{background:linear-gradient(135deg,rgba(245,166,35,0.08),rgba(55,138,221,0.08));border:1px solid rgba(245,166,35,0.2);border-radius:14px;padding:24px;margin-bottom:20px;text-align:center}
.hero-title{font-size:22px;font-weight:700;color:#F5A623;margin-bottom:8px}
.hero-sub{font-size:13px;color:rgba(255,255,255,0.5);line-height:1.6}
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:16px 0}
.price-card{background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:10px;padding:14px;text-align:center}
.price-layer{font-size:11px;color:rgba(255,255,255,0.4);margin-bottom:6px}
.price-au{font-size:20px;font-weight:700;color:#F5A623}
.price-sub{font-size:10px;color:rgba(255,255,255,0.3);margin-top:3px}
.card{background:#0d0d20;border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:20px;margin-bottom:14px}
.card-title{font-size:13px;font-weight:500;color:#00b4ff;margin-bottom:14px;display:flex;align-items:center;gap:6px}
.field{margin-bottom:12px}
.field label{display:block;font-size:11px;color:rgba(255,255,255,0.4);margin-bottom:4px}
.field input,.field select,.field textarea{width:100%;background:#060e1a;border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:8px 12px;color:#fff;font-size:13px;font-family:sans-serif}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:#F5A623}
.field textarea{height:70px;resize:vertical}
.cell-grid{display:inline-flex;flex-direction:column;gap:2px;margin-bottom:8px}
.col-row-a{display:flex;gap:2px;padding-left:20px;margin-bottom:1px}
.col-lbl-a{font-size:7px;color:#4A90D9;text-align:center;font-weight:700;flex-shrink:0}
.row-line-a{display:flex;gap:2px;align-items:center}
.row-lbl-a{font-size:7px;color:#4A90D9;width:18px;text-align:right;padding-right:3px;flex-shrink:0;font-weight:700}
.gc{width:26px;height:26px;border-radius:4px;border:1.5px solid;cursor:pointer;font-size:7px;display:flex;align-items:center;justify-content:center;transition:all 0.1s;flex-shrink:0}
.gc:hover{border-color:#F5A623;color:#F5A623;transform:scale(1.2);z-index:5}
.gc.sel{border-color:#F5A623;background:rgba(245,166,35,0.2);color:#F5A623}
.gc.taken{border-color:#E23B3B;background:rgba(226,59,59,0.1);color:#E23B3B;cursor:not-allowed}
.gc.pending{border-color:#FFD700;background:rgba(255,215,0,0.08);color:#FFD700;cursor:not-allowed}
.sel-info{font-size:11px;color:rgba(255,255,255,0.3);margin-top:4px}
.sel-info b{color:#F5A623}
.submit-btn{width:100%;padding:13px;background:rgba(245,166,35,0.15);border:1px solid #F5A623;border-radius:10px;color:#F5A623;font-size:14px;font-weight:500;cursor:pointer;transition:all 0.15s}
.submit-btn:hover{background:rgba(245,166,35,0.28)}
.status{margin-top:12px;padding:12px;border-radius:8px;font-size:13px;text-align:center;display:none;line-height:1.5}
.status.ok{background:rgba(39,174,96,0.12);border:1px solid #27AE60;color:#27AE60;display:block}
.status.err{background:rgba(226,59,59,0.12);border:1px solid #E23B3B;color:#E23B3B;display:block}
.legend{display:flex;gap:12px;flex-wrap:wrap;margin-top:6px}
.leg{display:flex;align-items:center;gap:4px;font-size:10px;color:rgba(255,255,255,0.4)}
