    <div class="field"><label data-i18n="desc">공간 설명</label><textarea id="fdesc" placeholder="이 공간을 어떻게 활용할지 설명해주세요"></textarea></div>
    <div class="field"><label data-i18n="link">링크 / 연락처</label><input id="flink" type="text" placeholder="https:// 또는 이메일"></div>
  </div>

  <div class="card">
    <div class="card-title">💰 <span data-i18n="payment">AU 결제 확인</span></div>
    <div style="background:rgba(245,166,35,0.06);border:1px solid rgba(245,166,35,0.2);border-radius:8px;padding:12px;margin-bottom:12px">
      <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px"><span style="color:rgba(255,255,255,0.5)">분양가</span><span id="priceDisp" style="color:#F5A623;font-weight:500">10 AU</span></div>
      <div style="display:flex;justify-content:space-between;font-size:13px;margin-bottom:6px"><span style="color:rgba(255,255,255,0.5)">월 유지비</span><span style="color:#F5A623;font-weight:500" id="monthlyDisp">2 AU/월</span></div>
      <div style="display:flex;justify-content:space-between;font-size:13px"><span style="color:rgba(255,255,255,0.5)">거래 수수료</span><span style="color:#F5A623;font-weight:500">3%</span></div>
    </div>
    <button class="submit-btn" onclick="apply()"><span data-i18n="submitBtn">분양 신청하기</span></button>
    <div class="status" id="status"></div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded",function(){
  applyLang();
  // 언어 변경시 재적용
  setInterval(applyLang,500);
});
const COLS='ABCDEFGHJKLMNOPQRS'.split('');
const PRICES={1:10,2:20,3:50};
const MONTHLY={1:2,2:4,3:8};
let selCell=null;
let cellData={};

const params=new URLSearchParams(location.search);
if(params.get('cell'))selCell=params.get('cell');

fetch('/dot-api/cells').then(r=>r.json()).then(d=>{
  cellData=d;buildGrid();
}).catch(()=>buildGrid());

const PAL=[
  {bg:'#1a0808',bd:'#FF4444'},{bg:'#1a0d00',bd:'#FF8C00'},{bg:'#1a1800',bd:'#FFD700'},
  {bg:'#0a1800',bd:'#7FFF00'},{bg:'#001a08',bd:'#00FF7F'},{bg:'#001a1a',bd:'#00FFFF'},
  {bg:'#000d1a',bd:'#00BFFF'},{bg:'#00001a',bd:'#4488FF'},{bg:'#0a001a',bd:'#9933FF'},
  {bg:'#1a001a',bd:'#FF00FF'},{bg:'#1a000d',bd:'#FF1493'},{bg:'#0d1a00',bd:'#AAFF00'},
  {bg:'#001a14',bd:'#20B2AA'},{bg:'#14001a',bd:'#DA70D6'},{bg:'#1a0a14',bd:'#FF69B4'},
  {bg:'#0a1400',bd:'#9ACD32'},{bg:'#00141a',bd:'#5FC0C0'},{bg:'#140a00',bd:'#FFA500'},
];
const TBGS_A={office:'#0a1828',shop:'#1e1200',game:'#041608',meet:'#0c0620',nft:'#180408',social:'#041414'};
const TCOLORS_A={office:'#378add',shop:'#F5A623',game:'#27AE60',meet:'#7B68EE',nft:'#E23B3B',social:'#1ABC9C'};
const ICONS_A={office:'🏢',shop:'🛒',game:'🎮',meet:'🤝',nft:'💎',social:'💬'};

function buildGrid(){
  const cg=document.getElementById('cellGrid');cg.innerHTML='';

  // 열 라벨
  const cr=document.createElement('div');cr.className='col-row-a';
  COLS.forEach(c=>{
    const d=document.createElement('div');d.className='col-lbl-a';
    d.style.width='26px';d.style.minWidth='26px';d.textContent=c;cr.appendChild(d);
  });
  cg.appendChild(cr);

  for(let r=1;r<=18;r++){
    const line=document.createElement('div');line.className='row-line-a';
    const rl=document.createElement('div');rl.className='row-lbl-a';rl.textContent=r;line.appendChild(rl);

    COLS.forEach((c,ci)=>{
      const id=c+r;
      const d=cellData[id]||{};
      const el=document.createElement('div');
      const p=PAL[(ci*3+r*7)%PAL.length];

      if(d.status==='approved'){
        el.className='gc taken';
        el.style.background=TBGS_A[d.type]||'#180408';
        el.style.borderColor=TCOLORS_A[d.type]||'#E23B3B';
        el.textContent=ICONS_A[d.type]||'✓';
      } else if(d.status==='pending'){
        el.className='gc pending';
        el.style.background='rgba(255,215,0,0.08)';
        el.style.borderColor='#FFD700';
        el.textContent='⏳';
      } else if(id===selCell){
        el.className='gc sel';
        el.style.background='rgba(245,166,35,0.2)';
        el.style.borderColor='#F5A623';
        el.textContent=id.length<=2?id:'';
      } else {
        el.className='gc';
        el.style.background=p.bg;
        el.style.borderColor=p.bd;
        el.textContent='';
      }

      el.title=id+(d.status==='approved'?' (분양완료)':d.status==='pending'?' (대기중)':' (분양가능)');
      el.addEventListener('click',()=>{
        if(d.status==='approved'||d.status==='pending')return;
        document.querySelectorAll('.gc').forEach(e=>{
          const dd=cellData[COLS[Array.from(e.parentNode.children).indexOf(e)-1]+(Array.from(e.parentNode.parentNode.children).indexOf(e.parentNode))]||{};
        });
        selCell=id;
        document.getElementById('selLabel').textContent=id;
        document.getElementById('selStatus').textContent='분양 가능';
        buildGrid();
      });
      line.appendChild(el);
    });
    cg.appendChild(line);
  }
}

document.getElementById('flayer').addEventListener('change',function(){
  const lyr=+this.value;
  document.getElementById('priceDisp').textContent=PRICES[lyr]+' AU';
  document.getElementById('monthlyDisp').textContent=MONTHLY[lyr]+' AU/월';
});

function apply(){
  if(!selCell){alert('칸을 먼저 선택해주세요!');return;}
  const userId=document.getElementById('fuserId').value.trim();
  const name=document.getElementById('fname').value.trim();
  if(!userId||!name){alert('유저 ID와 공간 이름을 입력해주세요!');return;}
  const layer=+document.getElementById('flayer').value;
  const data={
    cellId:selCell,userId,name,
    type:document.getElementById('ftype').value,
    layer,auAmount:PRICES[layer],
    desc:document.getElementById('fdesc').value,
    link:document.getElementById('flink').value,
  };
  const st=document.getElementById('status');
  fetch('/dot-api/purchase',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)})
  .then(r=>r.json()).then(d=>{
    if(d.ok){
      st.className='status ok';
      st.textContent='✅ '+selCell+' 분양 신청 완료!\n관리자 승인 후 입주가 확정됩니다.\n납부 AU: '+PRICES[layer]+' AU';
    } else {
      st.className='status err';
      st.textContent='❌ '+d.msg;
    }
  }).catch(e=>{st.className='status err';st.textContent='❌ 오류: '+e.message;});
}
</script>

<script>
