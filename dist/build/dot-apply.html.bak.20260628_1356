  };
  var t=H[lang];if(!t)return;
  function s(sel,txt){var el=document.querySelector(sel);if(el)el.textContent=txt;}
  function sa(sel,txt){document.querySelectorAll(sel).forEach(function(el){el.textContent=txt;});}
  function runLang(){
    s('.hero-title',t.title);
    s('.hero-sub',t.sub);
    s('.submit-btn',t.btn);
    document.querySelectorAll('.card-title span').forEach(function(el,i){
      var keys=['sel','info','pay'];if(t[keys[i]])el.textContent=t[keys[i]];
    });
    document.querySelectorAll('label').forEach(function(el){
      var map={
        '유저 ID':'uid','공간 이름':'name','공간 유형':'type',
        '레이어':'layer','공간 설명':'desc','링크 / 연락처':'link'
      };
      var k=map[el.textContent.trim()];if(k&&t[k])el.textContent=t[k];
    });
    document.querySelectorAll('.price-sub').forEach(function(el,i){
      var ms=['m1','m2','m3'],ls=['l1','l2','l3'];
      if(t[ls[i]]&&t[ms[i]])el.innerHTML=t[ls[i]]+'<br>'+t[ms[i]];
    });
    var fee=document.querySelector('.hero>div:last-child');
    if(fee&&fee.textContent.includes('수수료'))fee.textContent=t.fee;
    var back=document.querySelector('a[href="/dot.html"]');
    if(back)back.textContent=t.back;
    var logo=document.querySelector('.logo span');
    if(logo)logo.textContent=t.title;
    if(lang==='ar')document.body.style.direction='rtl';
    
};
  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded',runLang);
  } else {
    runLang();
    setTimeout(runLang,500);
    setTimeout(runLang,1500);
  }
})();
</script>
