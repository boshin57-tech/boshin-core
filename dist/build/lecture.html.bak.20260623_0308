.bc{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:6px;padding:10px;display:flex;flex-direction:column;align-items:center;gap:7px;width:100%;max-width:520px}
canvas#goban{display:block;cursor:crosshair}
