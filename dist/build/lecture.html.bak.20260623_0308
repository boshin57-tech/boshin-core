<script>
const peers={};
const RTC_CFG={iceServers:[{urls:'stun:stun.l.google.com:19302'},{urls:'stun:stun1.l.google.com:19302'}]};

async function p2pInit(){
  if(!socket)return;
  socket.emit('p2p-join',{roomId:ROOM_ID,userId:USER_ID,role:ROLE});

  socket.on('p2p-user-joined',async({userId,socketId,role})=>{
    appendChat('시스템',`${userId} 입장`,role==='pro'?'pro':'stu');
    if(ROLE==='pro'||MODE==='pro'){
      const pc=createPC(socketId);
      if(localStream)localStream.getTracks().forEach(t=>pc.addTrack(t,localStream));
      const offer=await pc.createOffer();
      await pc.setLocalDescription(offer);
      socket.emit('p2p-offer',{to:socketId,offer,roomId:ROOM_ID});
    }
  });

  socket.on('p2p-offer',async({from,offer})=>{
    const pc=createPC(from);
    if(localStream)localStream.getTracks().forEach(t=>pc.addTrack(t,localStream));
    await pc.setRemoteDescription(new RTCSessionDescription(offer));
    const answer=await pc.createAnswer();
    await pc.setLocalDescription(answer);
    socket.emit('p2p-answer',{to:from,answer,roomId:ROOM_ID});
  });

  socket.on('p2p-answer',async({from,answer})=>{
    if(peers[from])await peers[from].setRemoteDescription(new RTCSessionDescription(answer));
  });

  socket.on('p2p-ice',async({from,candidate})=>{
    if(peers[from])try{await peers[from].addIceCandidate(new RTCIceCandidate(candidate));}catch(e){}
  });

  socket.on('p2p-user-left',({socketId})=>{
    if(peers[socketId]){peers[socketId].close();delete peers[socketId];}
    const v=document.getElementById('v-'+socketId);
    if(v)v.remove();
    appendChat('시스템','수강생이 나갔습니다.','ai');
  });
}

function createPC(socketId){
  const pc=new RTCPeerConnection(RTC_CFG);
  peers[socketId]=pc;
  pc.onicecandidate=e=>{if(e.candidate)socket.emit('p2p-ice',{to:socketId,candidate:e.candidate,roomId:ROOM_ID});};
  pc.ontrack=e=>{
    let v=document.getElementById('v-'+socketId);
    if(!v){
      const wrap=document.createElement('div');wrap.className='sv';wrap.id='w-'+socketId;
      v=document.createElement('video');v.id='v-'+socketId;
      v.autoplay=true;v.playsinline=true;v.style.cssText='width:100%;height:100%;object-fit:cover;border-radius:4px';
      wrap.appendChild(v);
      document.getElementById('stu-row').appendChild(wrap);
    }
    v.srcObject=e.streams[0];
  };
  pc.onconnectionstatechange=()=>{
    if(pc.connectionState==='disconnected'||pc.connectionState==='failed'){
      pc.close();delete peers[socketId];
      const w=document.getElementById('w-'+socketId);if(w)w.remove();
    }
  };
  return pc;
}

// 기존 connectSocket 완료 후 P2P 초기화
const _origConnect=connectSocket;
connectSocket=function(){
  _origConnect();
  setTimeout(p2pInit,500);
};

