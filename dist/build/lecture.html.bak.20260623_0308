.bct{padding:4px 9px;font-size:11px;border:1px solid #333;border-radius:4px;background:#222;color:#ccc;cursor:pointer}
.bct:hover{background:#2a2a2a;color:#ccc}
.bct.pr{background:#fff;color:#111;border-color:#fff;font-weight:500}
.bs{width:185px;display:flex;flex-direction:column;gap:7px;flex-shrink:0}
.bcard{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:5px;padding:9px}
.bct2{font-size:10px;color:#ccc;margin-bottom:5px}
.bcn{font-size:11px;font-weight:500;color:#ccc}
.bcs2{font-size:10px;color:#bbb;margin-top:2px}
.pw{background:#222;border-radius:99px;height:3px;overflow:hidden;margin-top:4px}
.pf{height:100%;border-radius:99px;background:#fff;transition:width .2s}
.pl{display:flex;justify-content:space-between;font-size:10px;color:#bbb;margin-top:4px}
.ms{display:flex;flex-wrap:wrap;gap:3px;max-height:130px;overflow-y:auto;margin-top:5px}
.mv{font-size:10px;padding:2px 4px;border-radius:3px;background:#222;color:#ccc;cursor:pointer}
.mv.cur{background:#fff;color:#111}
.cr{display:flex;justify-content:space-between;font-size:11px;color:#ccc;margin-top:4px}
.cn{font-size:13px;font-weight:500;color:#ccc}
#ai-box{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:5px;padding:8px;font-size:11px;color:#ddd;line-height:1.5;min-height:40px;width:100%;max-width:520px}
.mi{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:5px;padding:7px;font-size:11px;color:#ccc;width:100%;max-width:520px;text-align:center}
.pi{padding:10px}
.ph{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px}
.ph h2{font-size:13px;font-weight:500;color:#ccc}
.sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(185px,1fr));gap:7px}
.sc{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:5px;padding:9px}
.sch{display:flex;align-items:center;gap:7px;margin-bottom:6px}
.sca{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500}
.scn{font-size:12px;font-weight:500;color:#ccc}
.scg{font-size:10px;color:#bbb}
.pill{font-size:10px;padding:2px 6px;border-radius:99px;font-weight:500;margin-left:auto}
.pon{background:#1b5e20;color:#a5d6a7}
.paw{background:#e65100;color:#ffcc80}
.pof{background:#222;color:#bbb}
.scl{display:flex;flex-direction:column;gap:6px}
.si{background:#1a1a1a;border:1px solid #2a2a2a;border-left:2px solid #333;border-radius:0 5px 5px 0;padding:8px 11px;display:flex;align-items:center;gap:9px}
