.mn{font-size:10px;color:#ccc;margin-bottom:1px}
.mt{font-size:11px;color:#ccc;line-height:1.4}
.ci{padding:6px;border-top:1px solid #2a2a2a;display:flex;gap:5px;flex-shrink:0}
