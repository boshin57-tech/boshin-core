<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:sans-serif;background:#111;color:#eee;height:100vh;display:flex;flex-direction:column}
#topbar{background:#1a1a1a;border-bottom:1px solid #333;padding:0 12px;height:46px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.logo{font-size:14px;font-weight:500}
.mode-tabs{display:flex;gap:4px}
.mtab{padding:4px 12px;border-radius:99px;font-size:11px;cursor:pointer;border:1px solid #333;background:#222;color:#ddd}
.mtab.m-ai{background:#1565c0;color:#fff;border-color:#1565c0}
.mtab.m-pro{background:#1b5e20;color:#fff;border-color:#1b5e20}
.mtab.m-avatar{background:#4a148c;color:#fff;border-color:#4a148c}
.dot{width:6px;height:6px;border-radius:50%;display:inline-block;margin-right:3px}
.dot-g{background:#4caf50}.dot-r{background:#e53935}.dot-y{background:#ff9800}
#app{display:flex;flex:1;overflow:hidden}
#sidebar{width:140px;background:#1a1a1a;border-right:1px solid #2a2a2a;display:flex;flex-direction:column;flex-shrink:0}
.sb-item{padding:10px 12px;cursor:pointer;font-size:12px;color:#ddd;border-left:2px solid transparent}
.sb-item:hover{background:#222;color:#ccc}
.sb-item.active{color:#fff;background:#222;border-left-color:#fff}
#content{flex:1;display:flex;flex-direction:column;overflow:hidden}
.panel{display:none;flex:1;overflow-y:auto}
.panel.active{display:flex;flex-direction:column}
.lg{display:grid;grid-template-columns:1fr 250px;flex:1;overflow:hidden}
.va{display:flex;flex-direction:column;overflow:hidden;border-right:1px solid #2a2a2a}
#local-video{width:100%;max-height:200px;background:#000;display:block;object-fit:cover}
#avatar-wrap{width:100%;height:200px;background:#0a0a1a;display:none;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:#ccc;font-size:12px}
.vid-ctrl{background:#111;padding:6px 10px;display:flex;align-items:center;gap:6px;border-top:1px solid #2a2a2a;flex-shrink:0}
.vbtn{width:28px;height:28px;border-radius:50%;background:#2a2a2a;border:none;color:#ccc;cursor:pointer;font-size:14px}
.vbtn.red{background:#c62828}
.vspacer{flex:1}
.timer{font-size:11px;color:#ccc}
.stu-row{display:flex;gap:4px;padding:6px;background:#161616;overflow-x:auto;flex-shrink:0;border-top:1px solid #2a2a2a;min-height:66px}
.sv{width:68px;height:52px;background:#1a1a1a;border-radius:4px;flex-shrink:0;position:relative;display:flex;align-items:center;justify-content:center;font-size:10px;color:#ccc;border:1px solid #2a2a2a}
.sl{position:absolute;bottom:2px;left:3px;font-size:9px;color:#fff;background:rgba(0,0,0,.6);padding:1px 3px;border-radius:2px}
.sd{position:absolute;top:3px;right:3px;width:6px;height:6px;border-radius:50%}
.rc{display:flex;flex-direction:column;background:#161616;overflow:hidden}
.sr{display:flex;border-bottom:1px solid #2a2a2a;flex-shrink:0}
.sb{flex:1;padding:8px;text-align:center;border-right:1px solid #2a2a2a}
.sb:last-child{border-right:none}
.sn{font-size:16px;font-weight:500;color:#fff}
.sl2{font-size:10px;color:#ccc;margin-top:1px}
.cw{flex:1;display:flex;flex-direction:column;overflow:hidden}
.ch{padding:7px 10px;border-bottom:1px solid #2a2a2a;font-size:11px;color:#ccc;flex-shrink:0}
.cm{flex:1;overflow-y:auto;padding:7px;display:flex;flex-direction:column;gap:6px;max-height:260px}
.msg{display:flex;gap:5px}
.msg-av{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:500;flex-shrink:0}
.msg.pro .msg-av{background:#1b5e20;color:#fff}
.msg.ai .msg-av{background:#1565c0;color:#fff}
.msg.avatar .msg-av{background:#4a148c;color:#fff}
