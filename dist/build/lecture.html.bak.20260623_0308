function avatarSpeak(text){
  if(!('speechSynthesis' in window))return;
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text);
  u.lang='ko-KR'; u.rate=0.88; u.pitch=1.05;
  const voices=speechSynthesis.getVoices().filter(v=>v.lang.includes('ko'));
  if(voices.length>0)u.voice=voices[avatarVoiceIdx%voices.length];
  u.onstart=()=>{
    const av=document.getElementById('av-status');
    if(av){av.textContent='🎙 강의 중...';av.style.color='#ce93d8';}
    document.getElementById('avatar-wrap').style.border='2px solid #ce93d8';
