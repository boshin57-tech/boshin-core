let boardSize=9,stones=[],moveHistory=[],currentMove=0,turnBlack=true;
const STARS={9:[[2,2],[2,6],[4,4],[6,2],[6,6]],13:[[3,3],[3,9],[6,6],[9,3],[9,9],[3,6],[6,3],[6,9],[9,6]],19:[[3,3],[3,9],[3,15],[9,3],[9,9],[9,15],[15,3],[15,9],[15,15]]};
const KNAMES={9:'순장바둑 9로 — 포석 기초',13:'순장바둑 13로 — 중반 전략',19:'순장바둑 19로 — 실전 포석'};
const DEMO={9:[{r:4,c:4,b:true},{r:2,c:2,b:false},{r:6,c:6,b:true},{r:2,c:6,b:false},{r:6,c:2,b:true},{r:4,c:2,b:false}],13:[{r:3,c:3,b:true},{r:9,c:9,b:false},{r:3,c:9,b:true},{r:9,c:3,b:false},{r:6,c:6,b:true},{r:3,c:6,b:false}],19:[{r:3,c:3,b:true},{r:15,c:15,b:false},{r:3,c:15,b:true},{r:15,c:3,b:false},{r:9,c:9,b:true},{r:3,c:9,b:false}]};
function getCS(n){return n===9?{cs:300,pad:20}:n===13?{cs:340,pad:18}:{cs:420,pad:20};}

function drawBoard(){
  const cv=document.getElementById('goban');if(!cv)return;
  const{cs,pad}=getCS(boardSize);cv.width=cs;cv.height=cs;
  const ctx=cv.getContext('2d'),n=boardSize,cell=(cs-pad*2)/(n-1);
  ctx.fillStyle='#c8922a';ctx.fillRect(0,0,cs,cs);
  ctx.strokeStyle='#000';ctx.lineWidth=2.5;
  for(let i=0;i<n;i++){
    ctx.beginPath();ctx.moveTo(pad+i*cell,pad);ctx.lineTo(pad+i*cell,cs-pad);ctx.stroke();
    ctx.beginPath();ctx.moveTo(pad,pad+i*cell);ctx.lineTo(cs-pad,pad+i*cell);ctx.stroke();
  }
  (STARS[n]||[]).forEach(([r,c])=>{ctx.beginPath();ctx.arc(pad+c*cell,pad+r*cell,n===19?4:3.5,0,Math.PI*2);ctx.fillStyle='#000';ctx.fill();});
  const rad=cell*0.46;
  stones.forEach((s,idx)=>{
    const px=pad+s.c*cell,py=pad+s.r*cell;
    ctx.beginPath();ctx.arc(px,py,rad,0,Math.PI*2);
    if(s.b){ctx.fillStyle='#111';ctx.fill();}
    else{ctx.fillStyle='#f5f5f5';ctx.fill();ctx.strokeStyle='#999';ctx.lineWidth=0.8;ctx.stroke();}
    if(idx===stones.length-1){ctx.beginPath();ctx.arc(px,py,rad*0.38,0,Math.PI*2);ctx.fillStyle=s.b?'#fff':'#333';ctx.fill();}
  });
}

function handleClick(e){
  if(!canControl()){return;}
  const cv=document.getElementById('goban');
  const rect=cv.getBoundingClientRect();
  const{cs,pad}=getCS(boardSize);
  const mx=(e.clientX-rect.left)*(cs/rect.width),my=(e.clientY-rect.top)*(cs/rect.height);
  const cell=(cs-pad*2)/(boardSize-1);
  const c=Math.round((mx-pad)/cell),r=Math.round((my-pad)/cell);
  if(c<0||c>=boardSize||r<0||r>=boardSize)return;
  if(stones.find(s=>s.r===r&&s.c===c))return;
  const stone={r,c,b:turnBlack};
  stones.push(stone);moveHistory=moveHistory.slice(0,currentMove);moveHistory.push(stone);currentMove++;
  turnBlack=!turnBlack;
  if(socket)socket.emit('board-move',{roomId:ROOM_ID,stone,move:currentMove,boardSize});
  drawBoard();updateUI();
  if(MODE==='ai'||MODE==='pro'){fetchAI(stone);}
  else if(MODE==='avatar')fetchAvatar(stone);
}

function setSize(n){
  boardSize=n;stones=[];moveHistory=[];currentMove=0;turnBlack=true;
  ['9','13','19'].forEach(s=>document.getElementById('btn'+s).classList.remove('active'));
  document.getElementById('btn'+n).classList.add('active');
  document.getElementById('kifu-title').textContent=KNAMES[n];
  if(socket)socket.emit('board-reset',{roomId:ROOM_ID,boardSize:n});
  updateUI();setTimeout(drawBoard,10);
}
function prevMove(){if(currentMove<=0)return;currentMove--;stones=moveHistory.slice(0,currentMove);turnBlack=currentMove%2===0;drawBoard();updateUI();}
function nextMove(){
  const demo=DEMO[boardSize]||[];
  if(currentMove<moveHistory.length){stones=moveHistory.slice(0,currentMove+1);currentMove++;}
  else if(currentMove<demo.length){const m=demo[currentMove];if(!stones.find(s=>s.r===m.r&&s.c===m.c)){stones.push(m);moveHistory.push(m);currentMove++;}}
  turnBlack=currentMove%2===0;drawBoard();updateUI();
}
function resetBoard(){stones=[];moveHistory=[];currentMove=0;turnBlack=true;if(socket)socket.emit('board-reset',{roomId:ROOM_ID,boardSize});drawBoard();updateUI();}
function shareBoard(){if(socket){socket.emit('board-sync-request',{roomId:ROOM_ID});alert('수강생에게 바둑판이 공유됩니다.');}}

function loadFromGoRoom(){
  fetch('/api/goroom-latest')
    .then(r=>r.json())
    .then(d=>{
      if(d.moves&&d.moves.length>0){
        stones=d.moves;moveHistory=d.moves;currentMove=d.moves.length;
        if(d.boardSize)boardSize=d.boardSize;
        drawBoard();updateUI();
        appendChat('시스템','실시간 대국 기보를 불러왔습니다.','ai');
      }else{appendChat('시스템','현재 진행 중인 대국이 없습니다.','ai');}
    }).catch(()=>appendChat('시스템','기보 불러오기 실패. 데모 기보를 사용합니다.','ai'));
}

function updateUI(){
  const total=(DEMO[boardSize]||[]).length;
  const pct=total>0?Math.round(currentMove/total*100):0;
  document.getElementById('prog-txt').textContent=`${currentMove}/${total}수`;
  document.getElementById('prog-bar').style.width=pct+'%';
  document.getElementById('turn-badge').textContent=turnBlack?'흑 차례':'백 차례';
  document.getElementById('turn-badge').className='tp '+(turnBlack?'tb':'tw');
  document.getElementById('move-list').innerHTML=moveHistory.map((m,i)=>`<span class="mv${i===currentMove-1?' cur':''}" onclick="jumpMove(${i+1})">${i+1}</span>`).join('');
}
function jumpMove(n){currentMove=n;stones=moveHistory.slice(0,n);turnBlack=n%2===0;drawBoard();updateUI();}

</script>
