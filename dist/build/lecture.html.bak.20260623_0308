.st{min-width:52px;font-size:11px;color:#bbb}
.kl{display:flex;flex-direction:column;gap:6px}
.ki{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:5px;padding:8px 11px;display:flex;align-items:center;gap:8px}
.kico{width:30px;height:30px;border-radius:4px;background:#222;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.knm{font-size:12px;font-weight:500;color:#ccc}
.ksb{font-size:10px;color:#bbb;margin-top:2px}
.kb{margin-left:auto;padding:3px 8px;font-size:11px;border:1px solid #333;border-radius:4px;background:#222;color:#ccc;cursor:pointer}

#chat-in { color: #fff !important; }
#chat-in::placeholder { color: #bbb !important; }
</style>
</head>
