// ── 시선추적 (치팅 감지) ──
let gazeActive = false;
let gazeOffTime = null;
let gazeWarned = false;
const GAZE_THRESHOLD = 3000; // 3초

async function startGazeTracking(){
  if(gazeActive) return;
  try {
    await faceapi.nets.tinyFaceDetector.loadFromUri('https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/weights');
    await faceapi.nets.faceLandmark68TinyNet.loadFromUri('https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/weights');
    const video = document.getElementById('gaze-video');
    const stream = await navigator.mediaDevices.getUserMedia({video:true});
    video.srcObject = stream;
    await new Promise(r => video.onloadedmetadata = r);
    gazeActive = true;
    console.log('[시선추적] 시작');
    gazeLoop(video);
  } catch(e) {
    console.warn('[시선추적] 초기화 실패:', e.message);
  }
}

async function gazeLoop(video){
  if(!gazeActive) return;
  const det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks(true);
  const alert = document.getElementById('gaze-alert');

  if(!det){
    // 얼굴 미감지
    if(!gazeOffTime) gazeOffTime = Date.now();
    const elapsed = Date.now() - gazeOffTime;
    if(elapsed > GAZE_THRESHOLD){
      if(alert) alert.style.display = 'block';
      if(!gazeWarned){
        gazeWarned = true;
        if(socket) socket.emit('cheat-alert',{roomId:ROOM_ID, userId:USER_ID, type:'face_missing', elapsed});
        console.warn('[치팅감지] 얼굴 이탈', elapsed+'ms');
      }
    }
  } else {
    gazeOffTime = null;
    gazeWarned = false;
    if(alert) alert.style.display = 'none';

    // 눈동자 방향 체크
    const lm = det.landmarks;
    const nose = lm.getNose()[3];
    const box = det.detection.box;
    const cx = box.x + box.width/2;
    const deviation = Math.abs(nose.x - cx) / box.width;
    if(deviation > 0.22){
      if(!gazeOffTime) gazeOffTime = Date.now();
      const elapsed = Date.now() - gazeOffTime;
      if(elapsed > GAZE_THRESHOLD && !gazeWarned){
        gazeWarned = true;
        if(socket) socket.emit('cheat-alert',{roomId:ROOM_ID, userId:USER_ID, type:'gaze_off', elapsed, deviation});
      }
    } else {
      gazeOffTime = null;
      gazeWarned = false;
    }
  }
  setTimeout(()=>gazeLoop(video), 500);
}

function stopGazeTracking(){
  gazeActive = false;
  const v = document.getElementById('gaze-video');
  if(v && v.srcObject) v.srcObject.getTracks().forEach(t=>t.stop());
  console.log('[시선추적] 중지');
}

// 바둑판 제어권
let boardController = null; // 제어권 가진 userId (null=강사만)

function canControl(){
  if(ROLE==='pro') return true;
  if(boardController === USER_ID) return true;
  if(!boardController) return true;
  return false;
}

function grantControl(targetUserId){
  if(ROLE!=='pro') return;
  if(socket) socket.emit('board-control',{roomId:ROOM_ID,targetUserId});
}

function revokeControl(){
  if(ROLE!=='pro') return;
  if(socket) socket.emit('board-control',{roomId:ROOM_ID,targetUserId:null});
}

// ── 강의 녹화 → GCS ──
let mediaRecorder = null;
let recordedChunks = [];
let recordingActive = false;

async function startRecording() {
  try {
    const streams = [];
    if(localStream) streams.push(localStream);
    const canvas = document.getElementById('goban');
    if(canvas) streams.push(canvas.captureStream(10));
    if(streams.length === 0){ alert('녹화할 스트림이 없습니다.'); return; }

    const combined = streams.length > 1
      ? new MediaStream([...streams[0].getTracks(), ...streams[1].getTracks()])
      : streams[0];

    mediaRecorder = new MediaRecorder(combined, {mimeType:'video/webm;codecs=vp8'});
    recordedChunks = [];
    mediaRecorder.ondataavailable = e => { if(e.data.size > 0) recordedChunks.push(e.data); };
    mediaRecorder.start(1000);
    recordingActive = true;

    const btn = document.getElementById('btn-rec');
    if(btn){ btn.textContent='⏹ 녹화중지'; btn.style.background='#dc2626'; }
    if(socket) socket.emit('recording-start', {roomId:ROOM_ID, userId:USER_ID});
    console.log('[녹화] 시작');
  } catch(e) {
    console.error('[녹화] 오류:', e.message);
    alert('녹화 오류: ' + e.message);
  }
}

async function stopRecording() {
  if(!mediaRecorder || !recordingActive) return;
  mediaRecorder.stop();
  recordingActive = false;

  const btn = document.getElementById('btn-rec');
  if(btn){ btn.textContent='⏫ 업로드중...'; btn.style.background='#f59e0b'; }

  mediaRecorder.onstop = async () => {
    const blob = new Blob(recordedChunks, {type:'video/webm'});
    const duration = Math.round(blob.size / 100000);

    // Base64 변환 후 GCS 업로드
    const reader = new FileReader();
    reader.onload = async () => {
      const base64 = reader.result.split(',')[1];
      try {
        const res = await fetch('https://tobmate.com/rec/upload-recording', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({roomId:ROOM_ID, userId:USER_ID, data:base64, duration})
        });
        const result = await res.json();
        if(result.ok){
          appendChat('시스템', '✅ 녹화 저장 완료: ' + result.url, 'sys');
          if(btn){ btn.textContent='⏺ 녹화'; btn.style.background='#374151'; }
        } else {
          appendChat('시스템', '❌ 업로드 실패', 'sys');
          if(btn){ btn.textContent='⏺ 녹화'; btn.style.background='#374151'; }
        }
      } catch(e) {
        console.error('[업로드]', e.message);
        if(btn){ btn.textContent='⏺ 녹화'; btn.style.background='#374151'; }
      }
    };
    reader.readAsDataURL(blob);
    if(socket) socket.emit('recording-stop', {roomId:ROOM_ID, userId:USER_ID, duration});
  };
}

function toggleRecording(){
  if(recordingActive) stopRecording();
  else startRecording();
}

let handRaised = false;
function toggleHand(){
