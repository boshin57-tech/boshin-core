<script>
// 녹화 기능
let isRecording=false, recordStart=0, mediaRecorder=null, recordChunks=[];

function toggleRecord(){
  if(!isRecording) startRecord(); else stopRecord();
}

async function startRecord(){
  try{
    const streams=[];
    if(localStream)streams.push(localStream);
    const canvas=document.getElementById('goban');
    if(canvas){const cs=canvas.captureStream(30);streams.push(cs);}
    if(streams.length===0){alert('녹화할 스트림이 없습니다.');return;}
    const combined=streams.length>1?streams[0]:streams[0];
    mediaRecorder=new MediaRecorder(combined,{mimeType:'video/webm;codecs=vp9'});
    recordChunks=[];
    mediaRecorder.ondataavailable=e=>{if(e.data.size>0)recordChunks.push(e.data);};
    mediaRecorder.onstop=saveRecord;
    mediaRecorder.start(1000);
    isRecording=true; recordStart=Date.now();
    if(socket)socket.emit('recording-start',{roomId:ROOM_ID,userId:USER_ID});
    document.getElementById('rec-btn').style.background='#e53935';
    document.getElementById('rec-btn').textContent='⏹ 녹화 중지';
    appendChat('시스템','녹화를 시작했습니다.','ai');
  }catch(e){alert('녹화 오류: '+e.message);}
}

function stopRecord(){
  if(mediaRecorder&&mediaRecorder.state!=='inactive')mediaRecorder.stop();
  isRecording=false;
  const dur=Math.round((Date.now()-recordStart)/1000);
  if(socket)socket.emit('recording-stop',{roomId:ROOM_ID,userId:USER_ID,duration:dur});
  document.getElementById('rec-btn').style.background='';
  document.getElementById('rec-btn').textContent='⏺ 녹화 시작';
  appendChat('시스템',`녹화 완료 (${dur}초)`, 'ai');
}

function saveRecord(){
  const blob=new Blob(recordChunks,{type:'video/webm'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download=`lecture_${ROOM_ID}_${new Date().toISOString().slice(0,19)}.webm`;
  a.click(); URL.revokeObjectURL(url);
}

