.szbar{display:flex;align-items:center;gap:5px;background:#1a1a1a;border:1px solid #2a2a2a;border-radius:5px;padding:6px 10px;width:100%;max-width:520px}
.szl{font-size:10px;color:#ccc;margin-right:3px}
