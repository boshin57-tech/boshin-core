<script>
const P=new URLSearchParams(location.search);
const ROOM_ID=P.get('room')||'pro-room-1';
const USER_ID=P.get('user')||'수강생';
const ROLE=P.get('role')||'pro';
let MODE=P.get('mode')||'ai';

function setMode(m){
  MODE=m;
  ['ai','pro','avatar'].forEach(x=>{
    const t=document.getElementById('mt-'+x);
    t.className='mtab'+(x===m?' m-'+m:'');
  });
  const labels={ai:'🤖 AI강의',pro:'📹 프로기사',avatar:'🧑‍🏫 AI아바타'};
  const infos={ai:'🤖 AI강의 — 착수하면 Claude가 자동 해설합니다',pro:'📹 프로기사 강의 — 실시간 WebRTC 화상강의',avatar:'🧑‍🏫 AI아바타 강의 — AI가 음성으로 강의합니다'};
  document.getElementById('s-mode').textContent=m.toUpperCase();
  const mi=document.getElementById('mode-info');if(mi)mi.textContent=infos[m]||'';
  document.getElementById('pro-label').textContent=m==='avatar'?'AI아바타 강사':m==='pro'?'프로기사':'AI강사';
  const lv=document.getElementById('local-video');
  const av=document.getElementById('avatar-wrap');
  if(m==='avatar'){lv.style.display='none';av.style.display='flex';}
  else{lv.style.display='block';av.style.display='none';}
  if(m==='pro'&&!localStream)startCam();
}

function goTab(n){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.sb-item').forEach(s=>s.classList.remove('active'));
  const p=document.getElementById('panel-'+n),s=document.querySelector(`.sb-item[data-tab="${n}"]`);
  if(p)p.classList.add('active');if(s)s.classList.add('active');
  if(n==='board')setTimeout(drawBoard,30);
}

let socket;
function connectSocket(){
  socket=io('https://tobmate.com',{path:'/lecture/socket.io/'});
  socket.on('connect',()=>{
    document.getElementById('cs').innerHTML='<span class="dot dot-g"></span>연결됨';
    if(ROLE==='student') setTimeout(startGazeTracking, 2000);
    socket.emit('join-room',{roomId:ROOM_ID,userId:USER_ID,role:ROLE,boardSize:boardSize});
  });
  socket.on('disconnect',()=>{document.getElementById('cs').innerHTML='<span class="dot dot-r"></span>끊김';});
  socket.on('room-update',d=>{
    document.getElementById('s-stu').textContent=d.memberCount;
    if(d.students) renderStuCards(d.students);
  });
  socket.on('chat',d=>appendChat(d.userId,d.text,d.role||'stu'));
  socket.on('board-move',d=>{stones.push(d.stone);currentMove++;if(d.boardSize&&d.boardSize!==boardSize)boardSize=d.boardSize;drawBoard();updateUI();});
  socket.on('board-reset',d=>{stones=[];moveHistory=[];currentMove=0;if(d.boardSize)boardSize=d.boardSize;drawBoard();updateUI();});
  socket.on('board-sync',d=>{stones=d.stones||[];currentMove=d.move||0;if(d.size)boardSize=d.size;drawBoard();updateUI();});
  socket.on('board-control-update',function(d){
    boardController = d.targetUserId;
    var cb = document.getElementById('control-bar');
    var cn = document.getElementById('ctrl-name');
    if(cb){ cb.style.display = boardController ? 'flex' : 'none'; }
    if(cn){ cn.textContent = boardController || ''; }
    var cv = document.getElementById('goban');
    if(cv){
      if(canControl()) cv.style.cursor='crosshair';
      else cv.style.cursor='not-allowed';
    }
    // 강사 패널 버튼 업데이트
    document.querySelectorAll('.grant-btn').forEach(function(btn){
      var uid = btn.dataset.uid;
