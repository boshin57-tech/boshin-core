// 기보 AI 복기 버튼 후보 옆으로 이동
(function(){
  function moveAIBtn(){
    var btns=Array.from(document.querySelectorAll('button'));
    var aiBtn=btns.find(function(b){return b.textContent.trim()==='기보 AI 복기';});
    var hoboBtn=btns.find(function(b){return b.textContent.trim()==='후보';});
    if(aiBtn&&hoboBtn&&!aiBtn.dataset.moved){
      aiBtn.dataset.moved='1';
      hoboBtn.parentNode.insertBefore(aiBtn,hoboBtn.nextSibling);
    }
  }
  setInterval(moveAIBtn,500);
})();

// 집표시 클릭 후 canvas 감시 — 순장 집표시로 덮어쓰기
(function(){
  var _watching=false;
  var _canvasOb=null;
  function watchCanvas(){
    if(_watching) return;
    _watching=true;
    var canvas=document.querySelector('canvas');
    if(!canvas) return;
    _canvasOb=new MutationObserver(function(){
      if(window._sjTerriPending){
        window._sjTerriPending=false;
        setTimeout(function(){window.showSJTerri&&window.showSJTerri();},100);
      }
    });
    _canvasOb.observe(canvas,{attributes:true,attributeFilter:['width','height']});
    // canvas 부모 감시
    var ob2=new MutationObserver(function(){
      if(window._sjTerriPending){
        window._sjTerriPending=false;
        setTimeout(function(){window.showSJTerri&&window.showSJTerri();},300);
      }
    });
    ob2.observe(document.body,{subtree:true,childList:true});
  }
  function addTerriListener(){
    var btns=Array.from(document.querySelectorAll('button'));
    var terriBtn=btns.find(function(b){return b.textContent.trim()==='집표시'&&!b.dataset.sjlisten;});
    if(!terriBtn) return;
    terriBtn.dataset.sjlisten='1';
    terriBtn.addEventListener('click',function(){
      window._sjTerriPending=true;
      watchCanvas();
      // React 처리 완료 후 실행
      setTimeout(function(){
        if(window._sjTerriPending){
          window._sjTerriPending=false;
          window.showSJTerri&&window.showSJTerri();
        }
      },1500);
    },true);
  }
  setInterval(addTerriListener,500);
})();

