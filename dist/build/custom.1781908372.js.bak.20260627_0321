    div.style.cssText = 'position:fixed;bottom:80px;right:20px;z-index:9998;padding:16px;background:#1e1e3f;border:2px solid '+color+';border-radius:12px;color:#fff;font-family:sans-serif;width:320px;box-shadow:0 4px 20px rgba(0,0,0,0.5);transition:background 0.2s,box-shadow 0.2s;';
    div.onmouseenter = function() {
