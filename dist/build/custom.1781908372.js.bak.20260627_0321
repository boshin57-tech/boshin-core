// SC_GAME_START 후 putAble 강제 설정
setInterval(function(){
  if(window.__REDUX_STORE__ && !window._putAbleFixSet){
    window._putAbleFixSet = true;
    var origDispatch = window.__REDUX_STORE__.dispatch.bind(window.__REDUX_STORE__);
    window.__REDUX_STORE__.dispatch = function(action){
      var result = origDispatch(action);
      if(action && action.type === 'UPDATE_ROOM_STATE' && action.room_state === 2){
        var state = window.__REDUX_STORE__.getState();
        var goState = state && (state.go || state.goRoom || state.game);
        console.log('[PUTFIX] UPDATE_ROOM_STATE PLAYING, store state:', JSON.stringify(goState && goState.players));
      }
      return result;
    };
  }
}, 300);

// 게임 중 통과 버튼 항상 활성화
setInterval(function(){
  if(window.location.pathname.indexOf('/go_room') === -1) return;
  var root = document.querySelector('#root');
  if(!root) return;
  var key = Object.keys(root).find(function(k){ return k.startsWith('__reactFiber'); });
  if(!key) return;
  var node = root[key];
  while(node){
    if(node.memoizedProps && node.memoizedProps.store){
      var st = node.memoizedProps.store.getState();
      if(st && st.go && st.go.room_state === 2) {
        node.memoizedProps.store.dispatch({type:'SET_PUTABLE', putAble:true});
      }
      break;
    }
    node = node.return;
  }
}, 1000);

