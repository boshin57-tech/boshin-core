      // 히스토리 차트
      bars.length > 0 ? [
        '<div style="font-size:11px;color:#aaa;margin-bottom:4px">'+window._tpiT('tpi_change')+'</div>',
        '<div style="display:flex;align-items:flex-end;height:44px;margin-bottom:12px">'+barHTML+'</div>',
      ].join('') : '',
