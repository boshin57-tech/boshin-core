// 서버 프록시로 금시세 조회
function fetchGoldPrice() {
  fetch('/au-api/au/goldprice')
    .then(function(r){ return r.json(); })
    .then(function(d) {
      if (d.ok && d.aud) {
        _goldPrice = d;
        var el = document.getElementById('au-gold-price');
        if (el) el.textContent = '1 AU = 금 1온스 ≈ AUD $' + d.aud.toLocaleString() + '  (USD $' + d.usd.toLocaleString() + ')';
        console.log('[AU] 금시세 갱신: AUD $' + d.aud);
      }
    }).catch(function(){});
}

function formatAU(val) {
  return (Math.round((val||0) * 100) / 100).toFixed(2);
}

function buildAUPanel(data) {
  var hist = (data.history || []).slice(-5).reverse();
  var histHTML = hist.length > 0 ? hist.map(function(h) {
    var color = h.type === 'earn' ? '#FFD700' : '#E24B4A';
    var sign  = h.type === 'earn' ? '+' : '-';
    var date  = new Date(h.date).toLocaleString(({'ko':'ko-KR','en':'en-US','zh':'zh-CN','ja':'ja-JP','ru':'ru-RU','ar':'ar-SA'}[window._auT('_lang')])||'en-US', {month:'numeric',day:'numeric',hour:'numeric',minute:'numeric'});
    return '<div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #333;font-size:11px">' +
      '<span style="color:#ccc">' + date + ' ' + (h.reason||'') + '</span>' +
      '<span style="color:'+color+';font-weight:500">' + sign + formatAU(h.amount) + ' mgAU</span>' +
    '</div>';
  }).join('') : '<div style="color:#aaa;font-size:11px;text-align:center;padding:8px">내역 없음</div>';

  return '<div style="font-family:sans-serif;color:#fff">' +
    '<div style="font-size:10px;color:#888;letter-spacing:0.07em;margin-bottom:8px">'+window._auT('wallet')+'</div>' +
    '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">' +
      '<div>' +
        '<div style="font-size:28px;font-weight:500;color:#FFD700">' + formatAU(data.balance) + '</div>' +
        '<div style="font-size:10px;color:#888">'+window._auT('balance')+'</div>' +
      '</div>' +
      '<div style="text-align:right">' +
        '<div style="font-size:11px;color:#aaa">'+window._auT('accumulated')+'</div>' +
        '<div style="font-size:16px;color:#FFD700;font-weight:500">+' + formatAU(data.total_earned) + ' mgAU</div>' +
        '<div style="font-size:11px;color:#C0C0C0;margin-top:2px">'+window._auT('streak')+' ' + (data.streak||0) + (window._auT('streak_unit')?' '+window._auT('streak_unit'):'')+'</div>' +
      '</div>' +
    '</div>' +
    '<div style="background:#111;border-radius:6px;padding:8px;margin-bottom:8px">' +
      '<div style="font-size:10px;color:#FFD700;margin-bottom:6px;font-weight:500">'+window._auT('pari')+'</div>' +
      '<div style="font-size:11px;color:#ddd;line-height:2.0;font-weight:500">' +
        window._auT('takeout')+'<br>' +
        window._auT('win_sponsor')+'<br>' +
        window._auT('lose_sponsor')+'<br>' +
        window._auT('win_player') +
      '</div>' +
    '</div>' +
    '<div style="font-size:11px;color:#FFD700;margin-bottom:4px;font-weight:500">'+window._auT('recent')+'</div>' +
    histHTML +
    '<div id="au-gold-price" style="font-size:11px;color:#FFD700;margin-top:8px;text-align:center;font-weight:500">' +
      '1 AU = 금 1온스 ≈ AUD $' + _goldPrice.aud.toLocaleString() + '  (USD $' + _goldPrice.usd.toLocaleString() + ')' +
    '</div>' +
  '</div>';
}

function injectAUWallet(data) {
  var btn = document.getElementById('au-wallet-btn');
  if (btn) {
    btn.innerHTML = '⭐ ' + formatAU(data.balance) + ' mgAU';
    var panel = document.getElementById('au-wallet-panel');
    if (panel) panel.innerHTML = buildAUPanel(data);
    return;
  }

  // AU 버튼
  btn = document.createElement('button');
  btn.id = 'au-wallet-btn';
  btn.style.cssText = 'position:fixed;bottom:20px;right:130px;z-index:9999;background:#1a1a0a;color:#FFD700;border:1px solid #FFD700;border-radius:50px;padding:8px 16px;font-size:12px;font-weight:500;cursor:pointer;font-family:sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.3);';
  btn.innerHTML = '⭐ ' + formatAU(data.balance) + ' mgAU';
  btn.onclick = function() {
    var panel = document.getElementById('au-wallet-panel');
    if (panel) {
      var show = panel.style.display === 'none';
      panel.style.display = show ? 'block' : 'none';
      if (show) { fetchGoldPrice(); loadAU(); }
    }
  };
  document.body.appendChild(btn);

  // AU 패널
  var panel = document.createElement('div');
  panel.id = 'au-wallet-panel';
  panel.style.cssText = 'position:fixed;bottom:80px;right:130px;z-index:9998;padding:16px;background:#1a1a0a;border:2px solid #FFD700;border-radius:12px;color:#fff;font-family:sans-serif;width:300px;box-shadow:0 4px 20px rgba(0,0,0,0.7);display:none;';
  panel.innerHTML = buildAUPanel(data);
  document.body.appendChild(panel);
}

function loadAU() {
  var token = localStorage.getItem('token');
  if (!token) return;
  fetch('/au-api/au/user/' + encodeURIComponent(token))
    .then(function(r){ return r.json(); })
    .then(function(d){ if (d.ok) injectAUWallet(d); })
    .catch(function(){});
}

