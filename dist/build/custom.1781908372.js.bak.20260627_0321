// AU 버튼 위 고정 표시
// ═══════════════════════════════════════
(function() {
  var _moveCount = 0;

  function isSpectator() {
    return true; // 관전자/플레이어 모두 승률바 표시 — 추후 플레이어만 숨기도록 수정
  }

  function injectWRBar() {
    if (document.getElementById('tpi-wr-bar')) return;
    var bar = document.createElement('div');
    bar.id = 'tpi-wr-bar';
    bar.style.cssText = 'position:fixed;right:0;bottom:320px;z-index:9997;background:rgba(0,0,0,0.85);border:1px solid rgba(255,255,255,0.8);border-right:none;border-radius:8px 0 0 8px;padding:8px 12px;display:flex;align-items:center;gap:8px;font-family:sans-serif;width:180px;';
    bar.innerHTML =
      '<div style="flex:1;height:12px;background:#222;border-radius:6px;overflow:hidden;position:relative;border:1px solid rgba(255,255,255,0.5);">' +
        '<div id="tpi-wr-fill" style="height:100%;width:50%;background:#111;border-radius:6px 0 0 6px;transition:width 0.8s"></div>' +
        '<div style="position:absolute;right:0;top:0;height:100%;width:50%;background:#fff;border-radius:0 6px 6px 0"></div>' +
      '</div>' +
      '<span id="tpi-wr-pct" style="font-size:11px;font-weight:600;color:#fff;min-width:36px;text-align:center">50%</span>';
    document.body.appendChild(bar);
  }

  function updateWR(blackPct) { window._lastWinrate = blackPct / 100;
    var fill = document.getElementById('tpi-wr-fill');
    var pct  = document.getElementById('tpi-wr-pct');
    if (!fill || !pct) return;
    var w = Math.max(5, Math.min(95, Math.round(blackPct)));
    fill.style.width = w + '%';
    pct.textContent = w + '%';
  }

  function removeWRBar() {
    var bar = document.getElementById('tpi-wr-bar');
    if (bar) bar.remove();
    _moveCount = 0;
  }

  // URL 감지
  setInterval(function() {
    var url = location.href;
    if (url.includes('/go_room')) {
      if (isSpectator()) {
        injectWRBar();
      } else {
        removeWRBar();
      }
    } else {
      removeWRBar();
    }
  }, 1000);

  // 소켓 훅
  setInterval(function() {
    if (window._goSocket && !window._goSocket._wrHooked) {
      window._goSocket._wrHooked = true;
      window._goSocket.on('sc_message', function(proto, err, data) {
        // 게임 시작 — 플레이어 목록 저장
        if (proto === 832 && data && data.players) {
          window._goRoomPlayers = data.players;
          console.log('[WR] 플레이어:', data.players.map(function(p){return p.user_id;}));
        }
        // 수 착수 — 승률 업데이트
        if (proto === 835 && err === 0 && data && isSpectator()) {
          _moveCount++;
          var base = 50 + (data.turn === 0 ? 3 : -3);
          var v = base + Math.sin(_moveCount * 0.4) * 10;
          updateWR(v);
        }
        // 게임 종료
        if (proto === 833) {
          setTimeout(removeWRBar, 3000);
          window._goRoomPlayers = [];
        }
      });
    }
  }, 500);

})();


