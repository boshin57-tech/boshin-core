    var goRoomUrl = 'https://tobmate.com';
    console.log('[SPA] goRoom 소켓 연결:', roomId);
    var s = io(goRoomUrl, {path: '/go_room/socket.io', reconnection: true, reconnectionAttempts: 10, reconnectionDelay: 500});
    window._custom2Socket = s;
    s.on('connect', function(){
