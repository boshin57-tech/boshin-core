(function(){
  function setupBoardClick(){
    var marks = document.getElementById('GoBoard0_BoardMarksCanvas');
    if(!marks || marks._clickSetup) return;
    marks._clickSetup = true;
    marks.addEventListener('mousedown', function(e){
      if(!window._putAbleAutoSet) return;
      if(!window._custom2Socket || !window._custom2Socket.connected) return;
      var w = marks.width;
      var margin = w / 22;
      var step = (w - margin*2) / 18;
      var cellX = Math.round((e.offsetX - margin) / step);
      var cellY = Math.round((e.offsetY - margin) / step);
      if(cellX < 0 || cellX > 18 || cellY < 0 || cellY > 18) return;
      var move = (cellY << 8) | cellX;
      var token = localStorage.getItem('token');
      var roomId = window._817room_id || (window._captured832 && window._captured832.room_id);
      if(window._mobileConfirmMode && /Mobi|Android/i.test(navigator.userAgent)) {
          showMoveConfirm(function(){ window._custom2Socket.emit('cs_message', 834, {token:token, room_id:roomId, move:move}); });
        } else {
          window._custom2Socket.emit('cs_message', 834, {token:token, room_id:roomId, move:move});
        }
      console.log('[BOARD] 착수!', cellX, cellY, move);
    });
    marks.addEventListener('mousemove', function(e){
      var target = document.getElementById('GoBoard0_TargetCanvas');
      if(!target) return;
      target.height = marks.height;
      var evt = new MouseEvent('mousemove', {bubbles:true, cancelable:true, clientX:e.clientX, clientY:e.clientY});
      Object.defineProperty(evt, 'offsetX', {value: e.offsetX});
      Object.defineProperty(evt, 'offsetY', {value: e.offsetY});
      target.dispatchEvent(evt);
    });
    console.log('[BOARD] 클릭 설정완료!');
  }
  setInterval(setupBoardClick, 1000);
})();

