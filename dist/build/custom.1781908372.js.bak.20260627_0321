(function() {
  var _tpiInjected = false;

  function getTierColor(tier) {
    return tier === 'platinum' ? '#378ADD'
         : tier === 'gold'     ? '#C9922A'
         : tier === 'silver'   ? '#888780'
         : '#8B5E3C'; // bronze
  }
  function getTierLabel(tier) {
    return tier === 'platinum' ? '💎 Platinum'
         : tier === 'gold'     ? '🥇 Gold'
         : tier === 'silver'   ? '🥈 Silver'
         : '🥉 Bronze';
  }

  function injectTPI(data) {
    if (document.getElementById('tpi-dashboard')) return;
    // 개인정보 페이지 내 go_level 표시 영역 찾기
    var target = document.querySelector('.MuiGrid-root') ||
                 document.querySelector('[class*="profile"]') ||
                 document.querySelector('[class*="mypage"]') ||
                 document.querySelector('[class*="info"]');
    if (!target) return;

    var color = getTierColor(data.tpi_tier);
    var tier  = getTierLabel(data.tpi_tier);

    // TPI 히스토리 미니 차트 데이터
    var hist  = data.tpi_history || [];
    var bars  = hist.slice(-10).map(function(h) { return h.value; });
    var maxV  = Math.max.apply(null, bars.concat([1000]));
    var barHTML = bars.map(function(v) {
      var h = Math.round((v / maxV) * 40);
      return '<div style="width:8px;height:'+h+'px;background:'+color+';border-radius:2px;opacity:0.8;margin:0 1px;align-self:flex-end"></div>';
    }).join('');

    // 최근 20국 승패
    var recent = data.recent_games || [];
    var recHTML = recent.slice(-10).map(function(r) {
      return '<span style="display:inline-block;width:14px;height:14px;border-radius:50%;background:'+(r===1?'#1D9E75':'#E24B4A')+';margin:1px;font-size:9px;line-height:14px;text-align:center;color:#fff">'+(r===1?'W':'L')+'</span>';
    }).join('');

    var winRate = recent.length > 0
      ? Math.round(recent.filter(function(r){return r===1;}).length / recent.length * 100)
      : 0;

    // 토글 버튼 생성
    var btn = document.createElement('button');
    btn.id = 'tpi-toggle-btn';
    btn.style.cssText = 'position:fixed;bottom:20px;right:20px;z-index:9999;background:#1a237e;color:#C9922A;border:1px solid #C9922A;border-radius:50px;padding:8px 16px;font-size:12px;font-weight:500;cursor:pointer;font-family:sans-serif;box-shadow:0 2px 8px rgba(0,0,0,0.3);';
