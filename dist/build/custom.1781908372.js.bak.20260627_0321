// PWA — Service Worker 등록 + 설치 배너
// ═══════════════════════════════════════
(function() {
  // Service Worker 등록 (기존 SW 해제 후 재등록)
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', function() {
      // 기존 SW 모두 해제
      navigator.serviceWorker.getRegistrations().then(function(regs) {
        regs.forEach(function(reg) {
          if (!reg.scope.includes('sw-custom')) {
            reg.unregister();
            console.log('[PWA] 기존 SW 해제:', reg.scope);
          }
        });
      });
      // 새 SW 등록
      navigator.serviceWorker.register('/sw-custom.js', {scope: '/'})
        .then(function(reg) {
          console.log('[PWA] SW 등록완료:', reg.scope);
          reg.update();
        })
        .catch(function(err) {
          console.warn('[PWA] SW 등록실패:', err);
        });
    });
  }

  // 홈화면 설치 배너
  var deferredPrompt = null;

  window.addEventListener('beforeinstallprompt', function(e) {
    e.preventDefault();
    deferredPrompt = e;
    showInstallBanner();
  });

  function showInstallBanner() {
    if (document.getElementById('_pwa_banner')) return;
    var banner = document.createElement('div');
    banner.id = '_pwa_banner';
    banner.style.cssText = [
      'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);',
      'z-index:99999;background:#1a237e;color:#fff;',
      'border-radius:12px;padding:12px 16px;',
      'display:flex;align-items:center;gap:12px;',
      'box-shadow:0 4px 20px rgba(0,0,0,0.4);',
      'font-family:sans-serif;font-size:14px;',
      'max-width:340px;width:90%;'
    ].join('');
    banner.innerHTML =
      '<span style="font-size:28px;">🀱</span>' +
      '<div style="flex:1;">' +
        '<div style="font-weight:bold;margin-bottom:2px;">Tobmate 앱 설치</div>' +
        '<div style="font-size:12px;opacity:0.8;">홈화면에 추가하면 더 빠르게!</div>' +
      '</div>' +
      '<button id="_pwa_install_btn" style="background:#FFD700;color:#1a237e;border:none;' +
        'padding:8px 14px;border-radius:20px;font-size:13px;font-weight:bold;cursor:pointer;">' +
        '설치' +
      '</button>' +
      '<button id="_pwa_close_btn" style="background:none;border:none;color:#fff;' +
        'font-size:18px;cursor:pointer;padding:0 4px;">✕</button>';

    document.body.appendChild(banner);

    document.getElementById('_pwa_install_btn').addEventListener('click', function() {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(function(result) {
        console.log('[PWA] 설치 선택:', result.outcome);
        deferredPrompt = null;
        banner.remove();
      });
    });

    document.getElementById('_pwa_close_btn').addEventListener('click', function() {
      banner.remove();
      // 24시간 후 다시 표시
      localStorage.setItem('_pwa_banner_closed', Date.now());
    });
  }

  // iOS Safari 설치 안내 (beforeinstallprompt 미지원)
  function isIOS() {
    return /iphone|ipad|ipod/i.test(navigator.userAgent);
  }
  function isInStandaloneMode() {
    return window.matchMedia('(display-mode: standalone)').matches ||
           window.navigator.standalone === true;
  }

  if (isIOS() && !isInStandaloneMode()) {
    var closed = localStorage.getItem('_pwa_ios_closed');
    if (!closed || Date.now() - closed > 86400000) {
      setTimeout(function() {
        if (document.getElementById('_pwa_ios_guide')) return;
        var guide = document.createElement('div');
        guide.id = '_pwa_ios_guide';
        guide.style.cssText = [
          'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);',
          'z-index:99999;background:#1a237e;color:#fff;',
          'border-radius:12px;padding:14px 16px;',
          'box-shadow:0 4px 20px rgba(0,0,0,0.4);',
          'font-family:sans-serif;font-size:13px;',
          'max-width:300px;width:90%;text-align:center;'
        ].join('');
        guide.innerHTML =
          '<div style="font-size:24px;margin-bottom:8px;">🀱</div>' +
          '<div style="font-weight:bold;margin-bottom:6px;">홈화면에 추가하기</div>' +
          '<div style="opacity:0.85;line-height:1.5;">' +
            'Safari 하단 <strong>공유 버튼 ⬆️</strong> 을 누른 후<br>' +
            '<strong>"홈 화면에 추가"</strong> 를 선택하세요.' +
          '</div>' +
          '<button onclick="this.parentElement.remove();localStorage.setItem(\'_pwa_ios_closed\',Date.now())" ' +
            'style="margin-top:10px;background:#FFD700;color:#1a237e;border:none;' +
            'padding:7px 20px;border-radius:20px;font-size:13px;font-weight:bold;cursor:pointer;">' +
            '확인' +
          '</button>';
        document.body.appendChild(guide);
      }, 3000);
    }
  }

})();

