// ===== go_room 진입시 올바른 방으로 redirect =====
(function(){
  var path = window.location.pathname;
  if(path.indexOf('/go_room:') < 0) return;
  
  var GT={GO:0,PUZZLE:1,PIECE_DESIGN:2,FFA:3,SKPNI:4,OMOK:5};
  var roomMap={1:'puzzle_room',2:'pdesign_room',3:'ffa_room',4:'skpni_room',5:'omok_room'};
  
  // localStorage에서 마지막 선택 콘텐츠 확인
  var content = parseInt(localStorage.getItem('_lastContent') || '0');
  console.log('[GOROOM CHECK] path:'+path+' lastContent:'+content);
  
  if(content !== GT.GO && content > 0){
    var roomType = roomMap[content];
    var roomId = path.split('/go_room:')[1];
    if(roomType && roomId){
      console.log('[GOROOM REDIRECT] '+roomType+':'+roomId);
      window.history.replaceState(null,'','/'+roomType+':'+roomId);
      localStorage.removeItem('_lastContent');
    }
  }
})();

// go_room roomURL 자동 설정
(function(){
  var p = window.location.pathname;
  var roomId = null;
  if(p.indexOf('/go_room/')===0){
    window._currentRoomId = p.split('/go_room/')[1];
    roomId=p.split('/go_room/')[1].split('?')[0].split('#')[0];
  } else if(p.indexOf('/go_room:')===0){
    roomId=p.split('/go_room:')[1].split('?')[0].split('#')[0];
  }
  if(roomId){
    sessionStorage.setItem('go_room_id',roomId);
    sessionStorage.setItem('go_room_url',window.location.protocol+'//'+window.location.hostname+'/go_room');
  }

  // lobby socket 후킹 - token 저장
  var _origSetSocketLobby = null;
  setInterval(function(){
    if(window._lobbySocket && !window._tokenHookSet){
      window._tokenHookSet = true;
      var _orig = window._lobbySocket.on.bind(window._lobbySocket);
      window._lobbySocket.on('sc_message', function(proto, err, data){
        if(proto===512 && data && data.user && data.user.token){
          window._userToken=data.token;
          localStorage.setItem("token",data.token);
          sessionStorage.setItem("go_room_token",data.token);
        }
      });
    }
  }, 300);

  // 로비에서 token sessionStorage 저장
  document.addEventListener('DOMContentLoaded', function(){
    var checkInterval = setInterval(function(){
      if(window._lobbySocket){
        clearInterval(checkInterval);
        window._lobbySocket.on('sc_message', function(proto, err, data){
          if(proto===512 && data && data.user && data.user.token){
            window._userToken=data.user.token;
            localStorage.setItem("token",data.user.token);
            sessionStorage.setItem("go_room_token",data.user.token);
            console.log("[TOKEN] 저장됨:", data.user.token);
          }
        });
      }
    }, 100);
  });
})();

