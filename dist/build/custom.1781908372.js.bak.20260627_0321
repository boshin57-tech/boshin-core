    if (btn) btn.innerHTML = '📊 TPI ' + data.tpi + ' (' + getTierLabel(data.tpi_tier).split(' ')[0] + ')';
  }

  function loadTPI() {
    var token = localStorage.getItem('token');
    if (!token) return;
    fetch('/tpi-api/tpi/user/' + encodeURIComponent(token))
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.ok) injectTPI(d);
      })
      .catch(function(){});
  }

  // URL 변경 감지 (React SPA)
  var _lastUrl = '';
  setInterval(function() {
    var url = location.href;
    if (url === _lastUrl) return;
    _lastUrl = url;
    _tpiInjected = false;
    // 개인정보 페이지일 때만 로드
    if (url.includes('/profile') || url.includes('/mypage') || url.includes('/info') || url.includes('/personal') || url.includes('/myinfo')) {
      (function(){
        var _t=0;
        var _pageLoad=Date.now();
        var _wait=setInterval(function(){
          _t+=100;
          var _fresh=window._tobLngTime && window._tobLngTime>_pageLoad;
          if(_fresh && (Date.now()-window._tobLngTime)>=800){
            clearInterval(_wait); loadTPI();
          } else if(_t>8000){ clearInterval(_wait); loadTPI(); }
        },100);
      })();
    }
  }, 500);

  // 사이드바 메뉴 클릭 감지
  document.addEventListener('click', function(e) {
    var txt = e.target && (e.target.textContent || '');
    if (txt.includes('개인정보') || txt.includes('My') || txt.includes('profile')) {
      _tpiInjected = false;
      (function(){
        var _t=0;
        var _pageLoad=Date.now();
        var _wait=setInterval(function(){
          _t+=100;
          var _fresh=window._tobLngTime && window._tobLngTime>_pageLoad;
          if(_fresh && (Date.now()-window._tobLngTime)>=800){
            clearInterval(_wait); loadTPI();
          } else if(_t>8000){ clearInterval(_wait); loadTPI(); }
        },100);
      })();
    }
  });

})();

