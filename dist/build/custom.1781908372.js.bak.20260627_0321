// 순장 집표시 + 집계산 핵심 함수
(function(){
  function removeIfDead(x,y,board,bs,color){
    var group=[],libs=0;
    var visited=new Array(bs*bs).fill(false);
    var stack=[[x,y]];
    function ap(x,y){return y*bs+x;}
    while(stack.length){
      var p=stack.pop();
      var px=p[0],py=p[1];
      if(px<0||px>=bs||py<0||py>=bs||visited[ap(px,py)]) continue;
      visited[ap(px,py)]=true;
      if(board[ap(px,py)]===0){libs++;continue;}
      if(board[ap(px,py)]!==color) continue;
      group.push([px,py]);
      stack.push([px+1,py],[px-1,py],[px,py+1],[px,py-1]);
    }
    if(libs===0) group.forEach(function(p){board[p[1]*bs+p[0]]=0;});
  }
  function floodFill(board,bs){
    var BLACK=1,WHITE=2;
    var territory=new Array(bs*bs).fill(0);
    var visited=new Array(bs*bs).fill(false);
    function ap(x,y){return y*bs+x;}
    for(var i=0;i<bs*bs;i++){
      if(board[i]!==0||visited[i]) continue;
      var group=[],borders=new Set(),stack=[i];
      while(stack.length){
        var idx=stack.pop();
        if(idx<0||idx>=bs*bs||visited[idx]) continue;
        visited[idx]=true;
        if(board[idx]!==0){borders.add(board[idx]);continue;}
        group.push(idx);
        var x=idx%bs,y=Math.floor(idx/bs);
        if(x+1<bs) stack.push(ap(x+1,y));
        if(x-1>=0) stack.push(ap(x-1,y));
        if(y+1<bs) stack.push(ap(x,y+1));
        if(y-1>=0) stack.push(ap(x,y-1));
      }
      if(borders.size===1){
        var owner=borders.values().next().value;
        group.forEach(function(idx){territory[idx]=owner;});
      }
    }
    return territory;
  }
  function buildBoard(data){
    var bs=data.boardSize||19;
    var rule=data.rule||0;
    var colors=data.colors||[1,2];
    var BLACK=1,WHITE=2;
    var board=new Array(bs*bs).fill(0);
    function ap(x,y){return y*bs+x;}
    if(rule===2){
      [[3,9],[3,15],[6,3],[6,15],[12,3],[12,15],[15,3],[15,9]].forEach(function(p){board[ap(p[0],p[1])]=BLACK;});
      [[3,3],[3,6],[3,12],[9,3],[9,15],[15,6],[15,12],[15,15]].forEach(function(p){board[ap(p[0],p[1])]=WHITE;});
    }
    var mh=data.move_history||[];
    var curColor=colors[0];
    mh.forEach(function(m){
      var x=m&255,y=(m>>8)&255;
      if(x<bs&&y<bs){
        board[ap(x,y)]=curColor;
        [[1,0],[-1,0],[0,1],[0,-1]].forEach(function(d){
          var nx=x+d[0],ny=y+d[1];
          if(nx>=0&&nx<bs&&ny>=0&&ny<bs&&board[ap(nx,ny)]===3-curColor)
            removeIfDead(nx,ny,board,bs,3-curColor);
        });
      }
      curColor=curColor===BLACK?WHITE:BLACK;
    });
    return {board:board,bs:bs,rule:rule};
  }
  function drawTerritory(board,territory,bs,bCount,wCount,komi){
    var BLACK=1,WHITE=2;
    var canvas=document.querySelector('canvas');
    if(!canvas) return;
    var ctx=canvas.getContext('2d');
    var W=canvas.width;
    var pad=W*0.042;
    var cell=(W-pad*2)/(bs-1);
    var rad=cell*0.46;
    function ap(x,y){return y*bs+x;}
    var img=new Image();
    img.src='/assets/img/board.jpg';
    img.onload=function(){
      ctx.drawImage(img,0,0,W,W);
      ctx.strokeStyle='rgba(0,0,0,0.55)';ctx.lineWidth=0.8;
      for(var i=0;i<bs;i++){
        ctx.beginPath();ctx.moveTo(pad+i*cell,pad);ctx.lineTo(pad+i*cell,pad+(bs-1)*cell);ctx.stroke();
        ctx.beginPath();ctx.moveTo(pad,pad+i*cell);ctx.lineTo(pad+(bs-1)*cell,pad+i*cell);ctx.stroke();
      }
      [[3,3],[3,9],[3,15],[9,3],[9,9],[9,15],[15,3],[15,9],[15,15]].forEach(function(s){
        ctx.beginPath();ctx.arc(pad+s[0]*cell,pad+s[1]*cell,3,0,Math.PI*2);
        ctx.fillStyle='#000';ctx.fill();
      });
      for(var y=0;y<bs;y++){
        for(var x=0;x<bs;x++){
          var idx=ap(x,y);
          if(board[idx]===0||territory[idx]!==0) continue;
          var cx=pad+x*cell,cy=pad+y*cell;
          ctx.beginPath();ctx.arc(cx,cy,rad,0,Math.PI*2);
          if(board[idx]===BLACK){ctx.fillStyle='#111';ctx.fill();}
          else{ctx.fillStyle='#f2f0e8';ctx.fill();ctx.strokeStyle='#aaa';ctx.lineWidth=0.8;ctx.stroke();}
        }
      }
      if(bCount!==undefined){
        var wFinal=wCount+komi;
        var diff=bCount-wFinal;
        var resultTxt=diff>0?'흑 승 B+'+Math.abs(diff).toFixed(1):diff<0?'백 승 W+'+Math.abs(diff).toFixed(1):'무승부';
        ctx.fillStyle='rgba(0,0,0,0.82)';
        ctx.fillRect(pad,W-pad-52,W-pad*2,48);
        ctx.textAlign='left';ctx.fillStyle='#fff';ctx.font='bold 13px sans-serif';
        ctx.fillText('흑 '+bCount+'집   백 '+wCount+'집 (+'+komi+'덤='+wFinal.toFixed(1)+')',pad+10,W-pad-30);
        ctx.textAlign='center';ctx.fillStyle='#ffd700';ctx.font='bold 15px sans-serif';
        ctx.fillText(resultTxt,W/2,W-pad-8);
      }
    };
  }
  window.showSJTerri=function(){
    var recordId=window.location.pathname.split(':')[1];
    fetch('/goroom-api/goroom-record/'+recordId)
      .then(function(r){return r.json();})
      .then(function(data){
        var res=buildBoard(data);
        var territory=floodFill(res.board,res.bs);
        var BLACK=1,WHITE=2;
        var bCount=0,wCount=0;
        for(var i=0;i<res.bs*res.bs;i++){
          if(res.board[i]===0){
            if(territory[i]===BLACK) bCount++;
            else if(territory[i]===WHITE) wCount++;
          }
        }
        // drawTerritoryOnCanvas 활용 (집 안 돌 제거)
        if(typeof drawTerritoryOnCanvas==='function'){
          drawTerritoryOnCanvas(res.board,territory,res.bs,bCount,wCount,data.komi||6.5,res.rule,null);
        } else {
          drawTerritory(res.board,territory,res.bs,bCount,wCount,data.komi||6.5);
        }
      });
  };
})();


// 언어 감지 — XHR 가로채기
(function(){
  var _origOpen = XMLHttpRequest.prototype.open;
  var _lngSet = false;
  XMLHttpRequest.prototype.open = function(method, url) {
    if(typeof url === 'string' && url.indexOf('/assets/locales/') >= 0) {
      var m = url.match(/locales\/([a-z]+)\.json/);
      if(m && !_lngSet) {
        var _map={'cn':'zh','jp':'ja','kp':'ko'};
        window._tobLng = _map[m[1]]||m[1];
        _lngSet = true;
        setTimeout(function(){ _lngSet = false; }, 3000);
      }
    }
    return _origOpen.apply(this, arguments);
  };
})();
// TPI 다국어
window._tpiT=function(k){
  var _map={'cn':'zh','jp':'ja','kp':'ko','ar':'ar','ru':'ru'};
  var _entries=performance.getEntriesByType('resource');
  var _found=null;
  for(var i=_entries.length-1;i>=0;i--){
    var _m=_entries[i].name.match(/locales\/([a-z]+)\.json/);
    if(_m){
      var _lng=_map[_m[1]]||_m[1];
      if(_lng!=='en'&&_lng!=='ko'){ _found=_lng; break; }
      if(!_found) _found=_lng;
    }
  }
  window._tobLng=_found||'en';
  var l=window._tobLng;
  var _D={
    ko:{winrate:'승률',tpi_change:'TPI 변화',recent:'최근 대국'},
    en:{winrate:'Win Rate',tpi_change:'TPI History',recent:'Recent Games'},
    zh:{winrate:'胜率',tpi_change:'TPI 变化',recent:'最近对局'},
    ja:{winrate:'勝率',tpi_change:'TPI 変化',recent:'最近の対局'},
    ru:{winrate:'Винрейт',tpi_change:'История TPI',recent:'Последние игры'},
    ar:{winrate:'نسبة الفوز',tpi_change:'تاريخ TPI',recent:'الألعاب الأخيرة'}
  };
  return(_D[l]||_D.en)[k]||k;
};

