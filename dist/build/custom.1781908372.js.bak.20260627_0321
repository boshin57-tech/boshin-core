    if(!rootEl) return;
    var fiberKey = Object.keys(rootEl).find(function(k){ return k.startsWith('__react'); });
    if(!fiberKey) return;
    function findStore(fiber) {
      if(!fiber) return null;
      if(fiber.memoizedProps && fiber.memoizedProps.store) return fiber.memoizedProps.store;
      if(fiber.memoizedState && fiber.memoizedState.store) return fiber.memoizedState.store;
      return findStore(fiber.child) || findStore(fiber.sibling);
    }
    var store = findStore(rootEl[fiberKey]);
    if(!store) return;
    var state = store.getState();
    if(state.goBoardReducer && !state.goBoardReducer.putAble) {
      store.dispatch({type: 'SET_PUTABLE', putAble: true});
      store.dispatch({type: 'UPDATE_ROOM', putAble: true});
      window._putAble = true;
