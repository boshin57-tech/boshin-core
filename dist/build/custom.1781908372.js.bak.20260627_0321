      setTimeout(tryConnectGoRoom, 500);
      return;
    }
    // React 원본 소켓이 이미 연결돼 있으면 그걸 사용
    if(window._goSocket && window._goSocket.connected){
      console.log('[SPA] React 소켓 재사용:', window._goSocket.id);
