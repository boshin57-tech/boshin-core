server {
    listen 80;
    listen 443 ssl;
    server_name tobmate.com www.tobmate.com 34.171.202.170 34.136.174.208;
    
    ssl_certificate /etc/letsencrypt/live/tobmate.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tobmate.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location /go_room/socket.io/ {
        rewrite ^/go_room(.*)$ $1 break;
        proxy_pass http://127.0.0.1:8005;
        add_header Access-Control-Allow-Origin "*";
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "*";
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }
    location /terms_and_policy {
        alias /home/boshin57/Tobmate_Live/dist/build/terms.html;
        default_type text/html;
    }

    # manifest.json Content-Type 설정
    location = /manifest.json {
        root /home/boshin57/Tobmate_Live/dist/build;
        add_header Content-Type "application/manifest+json";
        add_header Cache-Control "no-cache";
    }

    # Service Worker 캐시 방지
    location = /sw-custom.js {
        root /home/boshin57/Tobmate_Live/dist/build;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        add_header Expires "0";
    }

    location /tpi-admin {
        alias /home/boshin57/Tobmate_Live/dist/build/tpi-admin.html;
        default_type text/html;
    }


    location /dot/ {
        alias /home/boshin57/Tobmate_Live/dist/build/dot/;
        default_type text/html;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    location /dot.html {
        alias /home/boshin57/Tobmate_Live/dist/build/dot.html;
        default_type text/html;
        add_header Cache-Control "no-cache";
    }
    location /dot-api/ {
        proxy_pass http://127.0.0.1:3333/dot-api/;
        proxy_set_header Host $host;
    }

    location /au-api/ {
        proxy_pass http://127.0.0.1:8097/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "Content-Type";
    }

    location /api/review {
        proxy_pass http://127.0.0.1:8016;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_pass_request_body on;
        proxy_set_header Content-Length $content_length;
        proxy_set_header Content-Type $content_type;
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "Content-Type";
    }


    location /assets/locales/ {
        root /home/boshin57/Tobmate_Live/dist/build;
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Pragma "no-cache";
        expires 0;
    }
    location /rec/ {
        proxy_pass http://127.0.0.1:8021/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    location /lecture/socket.io/ {
        proxy_pass http://127.0.0.1:8018;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }

    location /avatar/eleven/ {
        proxy_pass http://127.0.0.1:8019/eleven/;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin *;
    }
    location /avatar/ {
        proxy_pass http://127.0.0.1:8019/;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "Content-Type";
    }

    location /lecture-ws/ {
        proxy_pass http://127.0.0.1:8018/;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin *;
    }

    location /api/goroom-latest {
        proxy_pass http://127.0.0.1:8020/goroom-latest;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin *;
    }

    location /api/lecture {
    
        rewrite ^/api/lecture(.*)$ /lecture$1 break;
        proxy_pass http://127.0.0.1:8016;
        proxy_set_header Host $host;
        add_header Access-Control-Allow-Origin *;
    }

    location /tpi-api/ {
        proxy_pass http://127.0.0.1:8097/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "Content-Type";
    }
    location /sau-api/ {
        proxy_pass http://127.0.0.1:8100/sau/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        add_header Access-Control-Allow-Origin *;
        add_header Access-Control-Allow-Methods "GET, POST, OPTIONS";
        add_header Access-Control-Allow-Headers "Content-Type";
    }

    location /shop/ {
        proxy_pass http://127.0.0.1:8023/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }

    location /goroom-api/ {
        proxy_pass http://localhost:8020/;
        proxy_http_version 1.1;
    }
    location / {
        proxy_pass http://127.0.0.1:8001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
    location /socket.io/ {
        proxy_pass http://127.0.0.1:8003;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }
}
server {
    listen 80;
    server_name ws.tobmate.com;
    location / {
        proxy_pass http://127.0.0.1:8003;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "Upgrade";
        proxy_set_header Host $host;
    }
}
